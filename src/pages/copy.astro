---
import Base from '../layouts/Base.astro';

const PLATFORMS = [
  { id: 'xiaohongshu', name: '小红书', emoji: '📕' },
  { id: 'zhihu', name: '知乎', emoji: '📘' },
  { id: 'wechat', name: '微信公众号', emoji: '💬' },
  { id: 'douyin', name: '抖音', emoji: '🎵' },
  { id: 'bilibili', name: '哔哩哔哩', emoji: '📺' },
  { id: 'weibo', name: '微博', emoji: '📢' },
  { id: 'qywechat', name: '企业微信', emoji: '👥' },
  { id: 'toutiao', name: '头条号', emoji: '🔥' },
  { id: 'jike', name: '即刻', emoji: '📌' },
];
---

<Base title="文案生成" active="copy">
<main class="flex flex-col h-[calc(100vh-3.5rem)] md:h-screen">
  <!-- 对话消息区域 -->
  <div id="chat-area" class="flex-1 overflow-y-auto px-4 py-6 space-y-4">
    <!-- 欢迎消息 -->
    <div class="flex gap-3 max-w-2xl">
      <div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-500 to-indigo-500 flex items-center justify-center text-white text-sm flex-shrink-0">🤖</div>
      <div class="bg-white rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm border border-gray-100">
        <p class="text-sm text-gray-700">你好！我是 AI 文案助手 ✨</p>
        <p class="text-sm text-gray-500 mt-1">请从下方选择一个目标平台，然后输入你的产品信息，我来帮你生成专业推广文案。</p>
      </div>
    </div>
    <!-- 对话消息会动态插入这里 -->
    <div id="messages-container"></div>
  </div>

  <!-- 底部输入区域 -->
  <div class="border-t border-gray-200 bg-white px-4 py-3">
    <!-- 平台选择器 -->
    <div class="flex items-center gap-2 mb-3 overflow-x-auto pb-1 no-scrollbar">
      <span class="text-xs text-gray-400 flex-shrink-0">平台：</span>
      {PLATFORMS.map(p => (
        <button class="platform-chip flex-shrink-0 flex items-center gap-1 px-3 py-1.5 rounded-full border border-gray-200 text-xs font-medium text-gray-600 hover:border-purple-300 hover:text-purple-600 transition-all" data-platform={p.id} data-name={p.name} data-emoji={p.emoji}>
          <span>{p.emoji}</span>
          <span>{p.name}</span>
        </button>
      ))}
    </div>

    <!-- 产品输入 + 额外要求 -->
    <div class="flex flex-col gap-2">
      <div class="flex gap-2">
        <textarea id="product-input" rows="2" class="flex-1 px-3 py-2 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-purple-500 focus:border-transparent resize-none" placeholder="输入产品名称、核心卖点、目标人群..."></textarea>
      </div>
      <div class="flex gap-2 items-center">
        <input id="extra-input" type="text" class="flex-1 px-3 py-2 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-purple-500 focus:border-transparent" placeholder="额外要求（选填）：风格、字数等">
        <button id="generate-btn" class="flex-shrink-0 px-5 py-2 rounded-xl text-white text-sm font-medium bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-700 hover:to-indigo-700 transition-all flex items-center gap-2 disabled:opacity-60 disabled:cursor-not-allowed">
          <span id="btn-text">✨ 生成</span>
        </button>
      </div>
    </div>
  </div>
</main>

<script>
  const PLATFORMS = [
    { id: 'xiaohongshu', name: '小红书', emoji: '📕' },
    { id: 'zhihu', name: '知乎', emoji: '📘' },
    { id: 'wechat', name: '微信公众号', emoji: '💬' },
    { id: 'douyin', name: '抖音', emoji: '🎵' },
    { id: 'bilibili', name: '哔哩哔哩', emoji: '📺' },
    { id: 'weibo', name: '微博', emoji: '📢' },
    { id: 'qywechat', name: '企业微信', emoji: '👥' },
    { id: 'toutiao', name: '头条号', emoji: '🔥' },
    { id: 'jike', name: '即刻', emoji: '📌' },
  ];

  let selectedPlatform = '';
  let lastResult = null;
  let lastProduct = '';
  let lastExtra = '';

  const spinnerSVG = '<svg class="animate-spin h-4 w-4 inline-block" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>';

  const messagesContainer = document.getElementById('messages-container');
  const chatArea = document.getElementById('chat-area');
  const generateBtn = document.getElementById('generate-btn');
  const btnText = document.getElementById('btn-text');

  // 平台芯片选择
  document.querySelectorAll('.platform-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('.platform-chip').forEach(c => {
        c.classList.remove('border-purple-500', 'bg-purple-50', 'text-purple-700');
        c.classList.add('border-gray-200', 'text-gray-600');
      });
      chip.classList.add('border-purple-500', 'bg-purple-50', 'text-purple-700');
      chip.classList.remove('border-gray-200', 'text-gray-600');
      selectedPlatform = chip.dataset.platform;
    });
  });

  function scrollBottom() {
    chatArea.scrollTop = chatArea.scrollHeight;
  }

  function addUserMessage(product, extra, platformName) {
    var div = document.createElement('div');
    div.className = 'flex gap-3 max-w-2xl ml-auto flex-row-reverse';
    div.innerHTML = '<div class="w-8 h-8 rounded-full bg-gradient-to-br from-green-500 to-emerald-500 flex items-center justify-center text-white text-sm flex-shrink-0">👤</div>' +
      '<div class="bg-purple-50 rounded-2xl rounded-tr-sm px-4 py-3 border border-purple-100">' +
      '<p class="text-xs text-purple-400 mb-1">📌 ' + platformName + '</p>' +
      '<p class="text-sm text-gray-800">' + escapeHtml(product) + '</p>' +
      (extra ? '<p class="text-xs text-gray-500 mt-1">💡 ' + escapeHtml(extra) + '</p>' : '') +
      '</div>';
    messagesContainer.appendChild(div);
    scrollBottom();
  }

  function addTypingIndicator() {
    var div = document.createElement('div');
    div.id = 'typing-indicator';
    div.className = 'flex gap-3 max-w-2xl';
    div.innerHTML = '<div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-500 to-indigo-500 flex items-center justify-center text-white text-sm flex-shrink-0">🤖</div>' +
      '<div class="bg-white rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm border border-gray-100">' +
      '<p class="text-sm text-gray-400">' + spinnerSVG + ' 正在生成文案...</p>' +
      '</div>';
    messagesContainer.appendChild(div);
    scrollBottom();
  }

  function removeTypingIndicator() {
    var el = document.getElementById('typing-indicator');
    if (el) el.remove();
  }

  function addResultMessage(content, platformId, platformName, platformEmoji) {
    var msgId = 'result-' + Date.now();
    var div = document.createElement('div');
    div.className = 'flex gap-3 max-w-3xl';
    div.innerHTML = '<div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-500 to-indigo-500 flex items-center justify-center text-white text-sm flex-shrink-0">🤖</div>' +
      '<div class="bg-white rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm border border-gray-100 flex-1 min-w-0">' +
      '<div class="flex items-center justify-between mb-2">' +
      '<span class="text-xs font-medium text-gray-500">' + platformEmoji + ' ' + platformName + ' · ' + new Date().toLocaleDateString('zh-CN') + '</span>' +
      '</div>' +
      '<div id="' + msgId + '" class="whitespace-pre-wrap text-sm text-gray-700 leading-relaxed bg-gray-50 rounded-xl p-3 overflow-y-auto mb-3" style="max-height:400px">' + escapeHtml(content) + '</div>' +
      '<div class="flex gap-2 flex-wrap">' +
      '<button class="copy-result-btn px-3 py-1.5 rounded-lg border border-purple-200 text-purple-600 hover:bg-purple-50 transition-all text-xs font-medium" data-content-id="' + msgId + '">📋 复制文案</button>' +
      '<button class="regenerate-btn px-3 py-1.5 rounded-lg border border-gray-200 text-gray-600 hover:bg-gray-50 transition-all text-xs font-medium">🔄 重新生成</button>' +
      '<a href="/generate" class="send-batch-btn px-3 py-1.5 rounded-lg bg-gradient-to-r from-green-500 to-emerald-600 text-white text-xs font-medium hover:opacity-90 transition-all inline-flex items-center gap-1">🚀 批量推广</a>' +
      '</div></div>';

    messagesContainer.appendChild(div);
    scrollBottom();

    // 绑定复制
    div.querySelector('.copy-result-btn').addEventListener('click', function() {
      var textEl = document.getElementById(this.dataset.contentId);
      if (textEl) {
        navigator.clipboard.writeText(textEl.textContent).then(() => {
          var btn = this;
          var orig = btn.innerHTML;
          btn.innerHTML = '✅ 已复制';
          setTimeout(function() { btn.innerHTML = orig; }, 2000);
        }).catch(() => alert('复制失败'));
      }
    });

    // 绑定重新生成
    div.querySelector('.regenerate-btn').addEventListener('click', () => generate());

    // 发送到批量推广
    div.querySelector('.send-batch-btn').addEventListener('click', (e) => {
      if (lastProduct) {
        try {
          localStorage.setItem('sm_pending_generate', JSON.stringify({
            product: lastProduct,
            extra: lastExtra,
            sourcePlatform: selectedPlatform,
            timestamp: Date.now(),
          }));
        } catch (e2) { console.error(e2); }
      }
    });
  }

  function addErrorMessage(msg) {
    var div = document.createElement('div');
    div.className = 'flex gap-3 max-w-2xl';
    div.innerHTML = '<div class="w-8 h-8 rounded-full bg-red-100 flex items-center justify-center text-red-500 text-sm flex-shrink-0">😢</div>' +
      '<div class="bg-red-50 rounded-2xl rounded-tl-sm px-4 py-3 border border-red-100">' +
      '<p class="text-sm text-red-600">' + escapeHtml(msg) + '</p>' +
      '<p class="text-xs text-red-400 mt-1">请检查网络后重试</p>' +
      '</div>';
    messagesContainer.appendChild(div);
    scrollBottom();
  }

  function setLoading(loading) {
    generateBtn.disabled = loading;
    if (loading) {
      btnText.innerHTML = spinnerSVG + ' 生成中';
    } else {
      btnText.innerHTML = '✨ 生成';
    }
  }

  function escapeHtml(text) {
    var div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  async function generate() {
    if (!selectedPlatform) { alert('请先选择平台'); return; }
    var product = document.getElementById('product-input').value.trim();
    if (!product) { alert('请输入产品信息'); return; }
    var extra = document.getElementById('extra-input').value.trim();
    lastProduct = product;
    lastExtra = extra;

    var platformInfo = PLATFORMS.find(function(p) { return p.id === selectedPlatform; });
    var platformName = platformInfo ? platformInfo.name : selectedPlatform;
    var platformEmoji = platformInfo ? platformInfo.emoji : '📄';

    // 添加用户消息
    addUserMessage(product, extra, platformEmoji + ' ' + platformName);

    // 清空输入
    document.getElementById('product-input').value = '';
    document.getElementById('extra-input').value = '';

    setLoading(true);
    addTypingIndicator();

    try {
      var res = await fetch('/api/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type: 'copy', product: product, platforms: [selectedPlatform], extra: extra }),
      });
      var data = await res.json();
      removeTypingIndicator();

      if (data.success && data.results && data.results.copy && data.results.copy.length > 0) {
        lastResult = data.results.copy[0];
        addResultMessage(lastResult.content, lastResult.platform, platformName, platformEmoji);

        // 保存历史
        try {
          var history = JSON.parse(localStorage.getItem('smart_marketing_history') || '[]');
          history.push({
            id: Date.now().toString(),
            date: new Date().toISOString().slice(0, 10),
            product: product,
            platforms: [selectedPlatform],
            copy: [lastResult],
            image: '',
            video: '',
          });
          localStorage.setItem('smart_marketing_history', JSON.stringify(history));
        } catch (e) { console.error('保存历史失败', e); }
      } else {
        addErrorMessage(data.error || '生成失败');
      }
    } catch (e) {
      removeTypingIndicator();
      addErrorMessage('网络错误');
    } finally {
      setLoading(false);
    }
  }

  generateBtn.addEventListener('click', generate);

  // 回车发送
  document.getElementById('product-input').addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      generate();
    }
  });
</script>

<style is:inline>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
</Base>
