---
import Base from '../layouts/Base.astro';

const PLATFORMS = [
  { id: 'xiaohongshu', name: '小红书', emoji: '📕' },
  { id: 'zhihu', name: '知乎', emoji: '📘' },
  { id: 'wechat', name: '微信公众号', emoji: '💬' },
  { id: 'douyin', name: '抖音', emoji: '🎵' },
  { id: 'bilibili', name: '哔哩哔哩', emoji: '📺' },
  { id: 'weibo', name: '微博', emoji: '📢' },
  { id: 'qywechat', name: '企业微信', emoji: '👥' },
  { id: 'toutiao', name: '头条号', emoji: '🔥' },
  { id: 'jike', name: '即刻', emoji: '📌' },
];
---

<Base title="批量推广" active="generate">
<main class="max-w-6xl mx-auto px-4 py-8">
  <!-- 来自文案生成的提示横幅 -->
  <div id="from-copy-banner" class="hidden bg-gradient-to-r from-green-50 to-emerald-50 border border-green-200 rounded-xl p-4 mb-5 flex items-center gap-3">
    <span class="text-xl">✅</span>
    <div class="flex-1">
      <p class="text-sm font-semibold text-green-800">已从「文案生成」导入产品信息</p>
      <p class="text-xs text-green-600 mt-0.5" id="from-copy-info"></p>
    </div>
    <button id="close-from-banner" class="text-green-600 hover:text-green-800 text-lg font-bold">✕</button>
  </div>

  <!-- 顶部输入区 -->
  <div class="bg-white rounded-2xl shadow-sm p-6 border border-gray-100 mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">批量推广生成</h2>
      <button id="toggle-input" class="text-sm text-purple-600 hover:text-purple-700 flex items-center gap-1">
        <span id="toggle-text">收起</span>
        <svg id="toggle-icon" class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/></svg>
      </button>
    </div>

    <div id="input-area" class="space-y-5">
      <!-- 产品描述 -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">产品描述</label>
        <textarea id="product-input" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-purple-500 focus:border-transparent resize-none" placeholder="输入产品名称、核心卖点、目标人群、使用场景等..."></textarea>
      </div>

      <!-- 平台多选 -->
      <div>
        <div class="flex items-center justify-between mb-2">
          <label class="block text-sm font-medium text-gray-700">选择平台</label>
          <div class="flex gap-2">
            <button id="select-all" class="text-xs text-purple-600 hover:text-purple-700 font-medium">全选</button>
            <span class="text-gray-300">|</span>
            <button id="deselect-all" class="text-xs text-gray-500 hover:text-gray-700 font-medium">取消全选</button>
          </div>
        </div>
        <div id="platform-checkboxes" class="grid grid-cols-3 gap-2">
          {PLATFORMS.map(p => (
            <label class="flex items-center gap-2 p-2.5 rounded-xl border border-gray-200 hover:border-purple-300 cursor-pointer transition-all has-[:checked]:border-purple-500 has-[:checked]:bg-purple-50">
              <input type="checkbox" value={p.id} class="platform-cb w-4 h-4 rounded text-purple-600 focus:ring-purple-500" checked>
              <span class="text-lg">{p.emoji}</span>
              <span class="text-sm text-gray-700">{p.name}</span>
            </label>
          ))}
        </div>
      </div>

      <!-- 额外要求 -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">额外要求</label>
        <input id="extra-input" type="text" class="w-full px-3 py-2 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-purple-500 focus:border-transparent" placeholder="风格、字数、特殊要求（选填）">
      </div>

      <!-- 生成内容类型 -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">生成内容</label>
        <div class="flex flex-wrap gap-3">
          <label class="flex items-center gap-2 px-4 py-2 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-300 transition-all has-[:checked]:border-purple-500 has-[:checked]:bg-purple-50">
            <input type="checkbox" id="type-copy" class="w-4 h-4 rounded text-purple-600 focus:ring-purple-500" checked>
            <span class="text-sm text-gray-700">✍️ 文案</span>
          </label>
          <label class="flex items-center gap-2 px-4 py-2 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-300 transition-all has-[:checked]:border-purple-500 has-[:checked]:bg-purple-50">
            <input type="checkbox" id="type-image" class="w-4 h-4 rounded text-purple-600 focus:ring-purple-500" checked>
            <span class="text-sm text-gray-700">🎨 配图提示词</span>
          </label>
          <label class="flex items-center gap-2 px-4 py-2 rounded-xl border border-gray-200 cursor-pointer hover:border-purple-300 transition-all has-[:checked]:border-purple-500 has-[:checked]:bg-purple-50">
            <input type="checkbox" id="type-video" class="w-4 h-4 rounded text-purple-600 focus:ring-purple-500" checked>
            <span class="text-sm text-gray-700">🎬 视频脚本</span>
          </label>
        </div>
      </div>

      <!-- 生成按钮 -->
      <button id="generate-btn" class="w-full py-3.5 rounded-xl text-white font-medium text-base bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-700 hover:to-indigo-700 transition-all flex items-center justify-center gap-2 disabled:opacity-60 disabled:cursor-not-allowed">
        <span id="btn-text" class="flex items-center gap-2">🚀 一键生成</span>
      </button>
    </div>
  </div>

  <!-- 结果区 -->
  <div id="result-section" class="hidden space-y-4">
    <!-- 顶部工具栏：平台筛选 + 一键复制全部 -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="flex items-center gap-2 flex-wrap" id="platform-filter">
          <span class="text-sm text-gray-500 font-medium mr-1">筛选：</span>
        </div>
        <button id="copy-all-global-btn" class="px-4 py-2 rounded-xl border border-purple-200 text-purple-600 hover:bg-purple-50 transition-all text-sm font-medium flex items-center gap-1.5 flex-shrink-0">
          📋 一键复制全部平台内容
        </button>
      </div>
    </div>

    <!-- 平台卡片容器 -->
    <div id="platform-cards-container" class="space-y-4"></div>

    <!-- 去发布管理 -->
    <div class="flex gap-3">
      <a href="/publish" class="flex-1 py-3.5 rounded-xl text-white font-medium bg-gradient-to-r from-green-500 to-emerald-600 hover:from-green-600 hover:to-emerald-700 transition-all text-sm flex items-center justify-center gap-2 shadow-sm text-center">
        📤 去发布管理 · 一键发布到平台
      </a>
      <button id="continue-gen-btn" class="px-5 py-3.5 rounded-xl border border-purple-200 text-purple-600 hover:bg-purple-50 transition-all text-sm font-medium flex items-center justify-center gap-2">
        🔄 继续生成
      </button>
    </div>
  </div>

  <!-- 空状态 -->
  <div id="empty-state" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-12 flex flex-col items-center justify-center text-gray-400">
    <div class="text-6xl mb-4">🚀</div>
    <p class="text-lg font-medium">批量生成多平台内容</p>
    <p class="text-sm mt-1">一次输入，同时生成文案 + 配图提示词 + 视频脚本</p>
  </div>
</main>

<script>
  const PLATFORMS = [
    { id: 'xiaohongshu', name: '小红书', emoji: '📕' },
    { id: 'zhihu', name: '知乎', emoji: '📘' },
    { id: 'wechat', name: '微信公众号', emoji: '💬' },
    { id: 'douyin', name: '抖音', emoji: '🎵' },
    { id: 'bilibili', name: '哔哩哔哩', emoji: '📺' },
    { id: 'weibo', name: '微博', emoji: '📢' },
    { id: 'qywechat', name: '企业微信', emoji: '👥' },
    { id: 'toutiao', name: '头条号', emoji: '🔥' },
    { id: 'jike', name: '即刻', emoji: '📌' },
  ];

  const spinnerSVG = '<svg class="animate-spin h-5 w-5" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>';

  let generatedData: { copy: any[]; image: string; video: any[] } = { copy: [], image: '', video: [] };
  let selectedTypes: { copy: boolean; image: boolean; video: boolean } = { copy: true, image: true, video: true };
  let currentFilter: string = 'all';

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function copyToClipboard(text: string, btn: HTMLElement) {
    navigator.clipboard.writeText(text).then(() => {
      const original = btn.innerHTML;
      btn.innerHTML = '✅ 已复制';
      setTimeout(() => { btn.innerHTML = original; }, 2000);
    }).catch(() => alert('复制失败'));
  }

  // 全选/取消全选
  document.getElementById('select-all')!.addEventListener('click', () => {
    document.querySelectorAll('.platform-cb').forEach((cb: Element) => {
      (cb as HTMLInputElement).checked = true;
    });
  });
  document.getElementById('deselect-all')!.addEventListener('click', () => {
    document.querySelectorAll('.platform-cb').forEach((cb: Element) => {
      (cb as HTMLInputElement).checked = false;
    });
  });

  // 折叠/展开输入区
  const inputArea = document.getElementById('input-area')!;
  const toggleIcon = document.getElementById('toggle-icon')!;
  const toggleText = document.getElementById('toggle-text')!;
  document.getElementById('toggle-input')!.addEventListener('click', () => {
    inputArea.classList.toggle('hidden');
    if (inputArea.classList.contains('hidden')) {
      toggleIcon.style.transform = 'rotate(180deg)';
      toggleText.textContent = '展开';
    } else {
      toggleIcon.style.transform = 'rotate(0deg)';
      toggleText.textContent = '收起';
    }
  });

  const generateBtn = document.getElementById('generate-btn')!;
  const btnText = document.getElementById('btn-text')!;

  function setLoading(loading: boolean) {
    generateBtn.disabled = loading;
    if (loading) {
      btnText.innerHTML = spinnerSVG + '<span>生成中...</span>';
    } else {
      btnText.innerHTML = '🚀 一键生成';
    }
  }

  function getSelectedPlatforms(): string[] {
    return Array.from(document.querySelectorAll('.platform-cb:checked')).map(
      (cb: Element) => (cb as HTMLInputElement).value
    );
  }

  function getSelectedTypes(): { copy: boolean; image: boolean; video: boolean } {
    return {
      copy: (document.getElementById('type-copy') as HTMLInputElement).checked,
      image: (document.getElementById('type-image') as HTMLInputElement).checked,
      video: (document.getElementById('type-video') as HTMLInputElement).checked,
    };
  }

  async function generate() {
    const product = (document.getElementById('product-input') as HTMLTextAreaElement).value.trim();
    if (!product) { alert('请输入产品描述'); return; }
    const platforms = getSelectedPlatforms();
    if (platforms.length === 0) { alert('请至少选择一个平台'); return; }
    const types = getSelectedTypes();
    if (!types.copy && !types.image && !types.video) { alert('请至少选择一种生成内容类型'); return; }
    selectedTypes = types;
    const extra = (document.getElementById('extra-input') as HTMLInputElement).value.trim();

    setLoading(true);
    try {
      const requests: Promise<Response>[] = [];

      if (types.copy && types.video) {
        requests.push(fetch('/api/generate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: 'batch', product, platforms, extra }),
        }));
      } else if (types.copy) {
        requests.push(fetch('/api/generate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: 'copy', product, platforms, extra }),
        }));
      } else if (types.video) {
        requests.push(fetch('/api/generate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: 'video', product, platforms, extra }),
        }));
      }

      if (types.image) {
        requests.push(fetch('/api/generate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: 'image', product, platforms, extra }),
        }));
      }

      const responses = await Promise.all(requests);
      const dataList = await Promise.all(responses.map(r => r.json()));

      generatedData = { copy: [], image: '', video: [] };
      dataList.forEach(data => {
        if (data.success && data.results) {
          if (data.results.copy) generatedData.copy = data.results.copy;
          if (data.results.image) generatedData.image = data.results.image;
          if (data.results.video) {
            if (Array.isArray(data.results.video)) {
              generatedData.video = data.results.video;
            } else {
              generatedData.video = [{ platform: 'all', content: data.results.video }];
            }
          }
        }
      });

      renderResults();

      try {
        const history = JSON.parse(localStorage.getItem('smart_marketing_history') || '[]');
        history.push({
          id: Date.now().toString(),
          date: new Date().toISOString().slice(0, 10),
          product,
          platforms,
          copy: generatedData.copy,
          image: generatedData.image || '',
          video: generatedData.video,
        });
        localStorage.setItem('smart_marketing_history', JSON.stringify(history));
      } catch (e) { console.error('保存历史失败', e); }

    } catch (e) {
      alert('网络错误，请重试');
    } finally {
      setLoading(false);
    }
  }

  function getVideoForPlatform(platformId: string): string {
    const specific = generatedData.video.find(v => v.platform === platformId);
    if (specific) return specific.content;
    const allVideo = generatedData.video.find(v => v.platform === 'all');
    if (allVideo) return allVideo.content;
    return generatedData.video.length > 0 ? generatedData.video[0].content : '';
  }

  function renderResults() {
    document.getElementById('empty-state')!.classList.add('hidden');
    document.getElementById('result-section')!.classList.remove('hidden');

    // 平台筛选按钮
    const filterContainer = document.getElementById('platform-filter')!;
    filterContainer.innerHTML = '<span class="text-sm text-gray-500 font-medium mr-1">筛选：</span>';
    const allBtn = document.createElement('button');
    allBtn.className = 'filter-btn px-3 py-1.5 rounded-lg border text-sm font-medium transition-all border-purple-500 bg-purple-50 text-purple-700';
    allBtn.dataset.platform = 'all';
    allBtn.textContent = '📋 全部';
    allBtn.addEventListener('click', () => setFilter('all'));
    filterContainer.appendChild(allBtn);

    generatedData.copy.forEach(item => {
      const p = PLATFORMS.find(pl => pl.id === item.platform);
      const btn = document.createElement('button');
      btn.className = 'filter-btn px-3 py-1.5 rounded-lg border text-sm font-medium transition-all border-gray-200 text-gray-600 hover:border-purple-300';
      btn.dataset.platform = item.platform;
      btn.textContent = `${p?.emoji || '📄'} ${p?.name || item.platform}`;
      btn.addEventListener('click', () => setFilter(item.platform));
      filterContainer.appendChild(btn);
    });

    currentFilter = 'all';
    renderPlatformCards();
  }

  function setFilter(platform: string) {
    currentFilter = platform;
    document.querySelectorAll('.filter-btn').forEach(btn => {
      if ((btn as HTMLElement).dataset.platform === platform) {
        btn.className = 'filter-btn px-3 py-1.5 rounded-lg border text-sm font-medium transition-all border-purple-500 bg-purple-50 text-purple-700';
      } else {
        btn.className = 'filter-btn px-3 py-1.5 rounded-lg border text-sm font-medium transition-all border-gray-200 text-gray-600 hover:border-purple-300';
      }
    });
    renderPlatformCards();
  }

  function renderPlatformCards() {
    const container = document.getElementById('platform-cards-container')!;
    container.innerHTML = '';

    const filteredCopy = currentFilter === 'all'
      ? generatedData.copy
      : generatedData.copy.filter(item => item.platform === currentFilter);

    filteredCopy.forEach(item => {
      const p = PLATFORMS.find(pl => pl.id === item.platform);
      const card = document.createElement('div');
      card.className = 'bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden';

      // === Card Header ===
      const header = document.createElement('div');
      header.className = 'px-5 py-3.5 border-b border-gray-100 flex items-center justify-between bg-gradient-to-r from-gray-50 to-white';
      header.innerHTML = `
        <h3 class="font-semibold text-gray-900 flex items-center gap-2">
          <span class="text-xl">${p?.emoji || '📄'}</span>
          <span>${p?.name || item.platform}</span>
        </h3>
      `;
      const headerCopyBtn = document.createElement('button');
      headerCopyBtn.className = 'px-3 py-1.5 rounded-lg border border-purple-200 text-purple-600 hover:bg-purple-50 transition-all text-xs font-medium flex items-center gap-1.5';
      headerCopyBtn.textContent = '📋 复制全部';
      headerCopyBtn.addEventListener('click', () => {
        const videoContent = selectedTypes.video ? getVideoForPlatform(item.platform) : '';
        const allText = [
          selectedTypes.copy ? `【文案】\n${item.content}` : '',
          selectedTypes.image ? `【配图提示词】\n${generatedData.image}` : '',
          selectedTypes.video && videoContent ? `【视频脚本】\n${videoContent}` : '',
        ].filter(Boolean).join('\n\n---\n\n');
        copyToClipboard(allText, headerCopyBtn);
      });
      header.appendChild(headerCopyBtn);
      card.appendChild(header);

      const cardBody = document.createElement('div');
      cardBody.className = 'p-5 space-y-3';

      // === 文案区域 ===
      if (selectedTypes.copy) {
        const copySection = document.createElement('div');
        copySection.className = 'rounded-xl border border-blue-100 bg-blue-50/30 overflow-hidden';
        const charCount = item.content.length;
        copySection.innerHTML = `
          <div class="px-4 py-2.5 flex items-center justify-between">
            <span class="text-sm font-medium text-blue-800 flex items-center gap-1.5">✍️ 文案 <span class="text-xs font-normal text-blue-500 bg-blue-100 px-1.5 py-0.5 rounded-full">${charCount} 字</span></span>
            <button class="copy-section-btn px-2.5 py-1 rounded-lg border border-blue-200 text-blue-600 hover:bg-blue-100 transition-all text-xs font-medium">📋 复制文案</button>
          </div>
          <div class="px-4 pb-4 whitespace-pre-wrap text-gray-700 text-sm leading-relaxed bg-white rounded-b-xl border-t border-blue-100 p-3" style="max-height:300px;overflow-y:auto;">${escapeHtml(item.content)}</div>
        `;
        copySection.querySelector('.copy-section-btn')!.addEventListener('click', function() {
          copyToClipboard(item.content, this as HTMLElement);
        });
        cardBody.appendChild(copySection);
      }

      // === 配图区域（默认折叠）===
      if (selectedTypes.image && generatedData.image) {
        const imageSection = document.createElement('div');
        imageSection.className = 'rounded-xl border border-amber-100 bg-amber-50/30 overflow-hidden';
        imageSection.innerHTML = `
          <button class="collapsible-toggle w-full px-4 py-2.5 flex items-center justify-between text-left hover:bg-amber-50/50 transition-all">
            <span class="text-sm font-medium text-amber-800 flex items-center gap-1.5">🎨 配图提示词</span>
            <span class="flex items-center gap-2">
              <span class="copy-section-btn px-2.5 py-1 rounded-lg border border-amber-200 text-amber-600 hover:bg-amber-100 transition-all text-xs font-medium">📋 复制提示词</span>
              <svg class="collapsible-icon w-4 h-4 text-amber-600 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </span>
          </button>
          <div class="collapsible-content hidden px-4 pb-4">
            <div class="whitespace-pre-wrap text-gray-700 text-sm leading-relaxed bg-white rounded-b-xl border-t border-amber-100 p-3" style="max-height:300px;overflow-y:auto;">${escapeHtml(generatedData.image)}</div>
          </div>
        `;
        cardBody.appendChild(imageSection);
      }

      // === 视频区域（默认折叠）===
      const videoContent = getVideoForPlatform(item.platform);
      if (selectedTypes.video && videoContent) {
        const videoSection = document.createElement('div');
        videoSection.className = 'rounded-xl border border-violet-100 bg-violet-50/30 overflow-hidden';
        videoSection.innerHTML = `
          <button class="collapsible-toggle w-full px-4 py-2.5 flex items-center justify-between text-left hover:bg-violet-50/50 transition-all">
            <span class="text-sm font-medium text-violet-800 flex items-center gap-1.5">🎬 视频脚本</span>
            <span class="flex items-center gap-2">
              <span class="copy-section-btn px-2.5 py-1 rounded-lg border border-violet-200 text-violet-600 hover:bg-violet-100 transition-all text-xs font-medium">📋 复制脚本</span>
              <svg class="collapsible-icon w-4 h-4 text-violet-600 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </span>
          </button>
          <div class="collapsible-content hidden px-4 pb-4">
            <div class="whitespace-pre-wrap text-gray-700 text-sm leading-relaxed bg-white rounded-b-xl border-t border-violet-100 p-3 mb-3" style="max-height:300px;overflow-y:auto;">${escapeHtml(videoContent)}</div>
            <div class="flex gap-2 justify-end">
              <a href="https://www.doubao.com" target="_blank" rel="noopener" class="px-3 py-1.5 rounded-lg bg-gradient-to-r from-blue-500 to-indigo-500 text-white text-xs font-medium hover:from-blue-600 hover:to-indigo-600 transition-all">🤖 打开豆包</a>
              <a href="https://www.jianying.com" target="_blank" rel="noopener" class="px-3 py-1.5 rounded-lg bg-gradient-to-r from-purple-500 to-pink-500 text-white text-xs font-medium hover:from-purple-600 hover:to-pink-600 transition-all">🎬 打开剪映</a>
            </div>
          </div>
        `;
        cardBody.appendChild(videoSection);
      }

      card.appendChild(cardBody);
      container.appendChild(card);
    });

    // 绑定折叠/展开事件
    container.querySelectorAll('.collapsible-toggle').forEach(toggle => {
      toggle.addEventListener('click', function(e) {
        // 如果点击的是复制按钮，不触发折叠
        if ((e.target as HTMLElement).closest('.copy-section-btn')) return;
        const content = (this as HTMLElement).querySelector('.collapsible-content')!;
        const icon = (this as HTMLElement).querySelector('.collapsible-icon')!;
        content.classList.toggle('hidden');
        if (content.classList.contains('hidden')) {
          icon.style.transform = 'rotate(0deg)';
        } else {
          icon.style.transform = 'rotate(180deg)';
        }
      });
    });

    // 绑定复制按钮事件（配图和视频区域的）
    container.querySelectorAll('.collapsible-toggle .copy-section-btn').forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        const card = (this as HTMLElement).closest('.rounded-xl')!;
        const contentEl = card.querySelector('.collapsible-content .whitespace-pre-wrap') as HTMLElement;
        if (contentEl) {
          copyToClipboard(contentEl.textContent || '', this as HTMLElement);
        }
      });
    });
  }

  // 一键复制全部平台内容
  document.getElementById('copy-all-global-btn')!.addEventListener('click', function() {
    let allText = '';
    generatedData.copy.forEach(item => {
      const p = PLATFORMS.find(pl => pl.id === item.platform);
      const parts: string[] = [`\n${'='.repeat(40)}`];
      parts.push(`${p?.emoji || ''} ${p?.name || item.platform}`);
      parts.push('='.repeat(40));
      if (selectedTypes.copy) parts.push(`\n【文案】\n${item.content}`);
      if (selectedTypes.image && generatedData.image) parts.push(`\n【配图提示词】\n${generatedData.image}`);
      if (selectedTypes.video) {
        const vc = getVideoForPlatform(item.platform);
        if (vc) parts.push(`\n【视频脚本】\n${vc}`);
      }
      allText += '\n' + parts.join('\n') + '\n';
    });
    copyToClipboard(allText.trim(), this as HTMLElement);
  });

  generateBtn.addEventListener('click', generate);

  // ===== 来自文案生成页的数据接收 =====
  (function checkPendingData() {
    try {
      const pendingStr = localStorage.getItem('sm_pending_generate');
      if (!pendingStr) return;
      const pending = JSON.parse(pendingStr);
      if (Date.now() - pending.timestamp > 5 * 60 * 1000) {
        localStorage.removeItem('sm_pending_generate');
        return;
      }

      const productInput = document.getElementById('product-input') as HTMLTextAreaElement;
      if (pending.product) productInput.value = pending.product;
      if (pending.extra) {
        const extraInput = document.getElementById('extra-input') as HTMLInputElement;
        extraInput.value = pending.extra;
      }
      if (pending.sourcePlatform) {
        const cb = document.querySelector(`.platform-cb[value="${pending.sourcePlatform}"]`) as HTMLInputElement;
        if (cb) {
          document.querySelectorAll('.platform-cb').forEach((c: Element) => { (c as HTMLInputElement).checked = false; });
          cb.checked = true;
        }
      }

      const banner = document.getElementById('from-copy-banner')!;
      const info = document.getElementById('from-copy-info')!;
      banner.classList.remove('hidden');
      const platformInfo = PLATFORMS.find(p => p.id === pending.sourcePlatform);
      info.textContent = `产品：${pending.product.slice(0, 30)}${pending.product.length > 30 ? '...' : ''}${platformInfo ? ' · 来自 ' + platformInfo.emoji + platformInfo.name : ''}`;
      localStorage.removeItem('sm_pending_generate');

      document.getElementById('close-from-banner')!.addEventListener('click', () => {
        banner.classList.add('hidden');
      });
    } catch (e) { console.error('读取待处理数据失败', e); }
  })();

  // 继续生成按钮（回到输入区）
  document.getElementById('continue-gen-btn')!.addEventListener('click', () => {
    inputArea.classList.remove('hidden');
    document.getElementById('toggle-icon')!.style.transform = 'rotate(0deg)';
    document.getElementById('toggle-text')!.textContent = '收起';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
</Base>
