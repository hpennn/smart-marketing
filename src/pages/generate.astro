---
import Base from '../layouts/Base.astro';

const PLATFORMS = [
  { id: 'xiaohongshu', name: '小红书', emoji: '📕' },
  { id: 'zhihu', name: '知乎', emoji: '📘' },
  { id: 'wechat', name: '微信公众号', emoji: '💬' },
  { id: 'douyin', name: '抖音', emoji: '🎵' },
  { id: 'bilibili', name: '哔哩哔哩', emoji: '📺' },
  { id: 'weibo', name: '微博', emoji: '📢' },
  { id: 'qywechat', name: '企业微信', emoji: '👥' },
  { id: 'toutiao', name: '头条号', emoji: '🔥' },
  { id: 'jike', name: '即刻', emoji: '📌' },
];
---

<Base title="批量推广" active="generate">
<main class="flex flex-col h-[calc(100vh-3.5rem)] md:h-screen">
  <!-- 对话消息区域 -->
  <div id="chat-area" class="flex-1 overflow-y-auto px-4 py-6 space-y-4">
    <!-- 欢迎消息 -->
    <div class="flex gap-3 max-w-3xl">
      <div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-500 to-indigo-500 flex items-center justify-center text-white text-sm flex-shrink-0">🤖</div>
      <div class="bg-white rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm border border-gray-100">
        <p class="text-sm text-gray-700">欢迎使用批量推广生成 🚀</p>
        <p class="text-sm text-gray-500 mt-1">我可以同时为你生成多平台的文案、配图提示词和视频脚本。请在下方配置你的需求：</p>
      </div>
    </div>

    <!-- 来自文案生成的提示 -->
    <div id="from-copy-banner" class="hidden bg-gradient-to-r from-green-50 to-emerald-50 border border-green-200 rounded-xl p-3 flex items-center gap-2 max-w-2xl">
      <span class="text-base">✅</span>
      <div class="flex-1">
        <p class="text-xs font-semibold text-green-800">已从「文案生成」导入</p>
        <p class="text-[11px] text-green-600" id="from-copy-info"></p>
      </div>
      <button id="close-from-banner" class="text-green-600 hover:text-green-800 text-sm font-bold">✕</button>
    </div>

    <div id="messages-container"></div>
  </div>

  <!-- 底部输入区域 -->
  <div class="border-t border-gray-200 bg-white px-4 py-3 max-h-[50vh] overflow-y-auto">
    <!-- 可折叠配置面板 -->
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-medium text-gray-500">📝 推广配置</span>
      <button id="toggle-input" class="text-xs text-purple-600 hover:text-purple-700 flex items-center gap-1">
        <span id="toggle-text">收起</span>
        <svg id="toggle-icon" class="w-3 h-3 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/></svg>
      </button>
    </div>

    <div id="input-area" class="space-y-3">
      <!-- 产品描述 -->
      <div>
        <textarea id="product-input" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-purple-500 focus:border-transparent resize-none" placeholder="输入产品名称、核心卖点、目标人群..."></textarea>
      </div>

      <!-- 平台多选 -->
      <div>
        <div class="flex items-center justify-between mb-1.5">
          <span class="text-xs text-gray-500">选择平台</span>
          <div class="flex gap-2">
            <button id="select-all" class="text-[11px] text-purple-600 hover:text-purple-700 font-medium">全选</button>
            <span class="text-gray-300 text-[11px]">|</span>
            <button id="deselect-all" class="text-[11px] text-gray-500 hover:text-gray-700 font-medium">取消</button>
          </div>
        </div>
        <div class="flex flex-wrap gap-1.5">
          {PLATFORMS.map(p => (
            <label class="platform-tag flex items-center gap-1 px-2.5 py-1.5 rounded-full border border-gray-200 cursor-pointer transition-all text-xs has-[:checked]:border-purple-500 has-[:checked]:bg-purple-50 has-[:checked]:text-purple-700">
              <input type="checkbox" value={p.id} class="platform-cb hidden" checked>
              <span>{p.emoji}</span>
              <span>{p.name}</span>
            </label>
          ))}
        </div>
      </div>

      <!-- 生成内容类型 -->
      <div class="flex flex-wrap gap-2">
        <label class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-gray-200 cursor-pointer transition-all text-xs has-[:checked]:border-purple-500 has-[:checked]:bg-purple-50">
          <input type="checkbox" id="type-copy" class="hidden" checked>
          <span>✍️ 文案</span>
        </label>
        <label class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-gray-200 cursor-pointer transition-all text-xs has-[:checked]:border-purple-500 has-[:checked]:bg-purple-50">
          <input type="checkbox" id="type-image" class="hidden" checked>
          <span>🎨 配图</span>
        </label>
        <label class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-gray-200 cursor-pointer transition-all text-xs has-[:checked]:border-purple-500 has-[:checked]:bg-purple-50">
          <input type="checkbox" id="type-video" class="hidden" checked>
          <span>🎬 视频</span>
        </label>
      </div>

      <!-- 额外要求 + 生成按钮 -->
      <div class="flex gap-2 items-center">
        <input id="extra-input" type="text" class="flex-1 px-3 py-2 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-purple-500 focus:border-transparent" placeholder="额外要求（选填）">
        <button id="generate-btn" class="flex-shrink-0 px-5 py-2 rounded-xl text-white text-sm font-medium bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-700 hover:to-indigo-700 transition-all flex items-center gap-2 disabled:opacity-60 disabled:cursor-not-allowed">
          <span id="btn-text">🚀 生成</span>
        </button>
      </div>
    </div>
  </div>
</main>

<script>
  const PLATFORMS = [
    { id: 'xiaohongshu', name: '小红书', emoji: '📕' },
    { id: 'zhihu', name: '知乎', emoji: '📘' },
    { id: 'wechat', name: '微信公众号', emoji: '💬' },
    { id: 'douyin', name: '抖音', emoji: '🎵' },
    { id: 'bilibili', name: '哔哩哔哩', emoji: '📺' },
    { id: 'weibo', name: '微博', emoji: '📢' },
    { id: 'qywechat', name: '企业微信', emoji: '👥' },
    { id: 'toutiao', name: '头条号', emoji: '🔥' },
    { id: 'jike', name: '即刻', emoji: '📌' },
  ];

  const spinnerSVG = '<svg class="animate-spin h-4 w-4 inline-block" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>';

  let generatedData = { copy: [], image: '', video: '' };

  const messagesContainer = document.getElementById('messages-container');
  const chatArea = document.getElementById('chat-area');
  const generateBtn = document.getElementById('generate-btn');
  const btnText = document.getElementById('btn-text');

  // 全选/取消
  document.getElementById('select-all').addEventListener('click', () => {
    document.querySelectorAll('.platform-cb').forEach(cb => { cb.checked = true; });
  });
  document.getElementById('deselect-all').addEventListener('click', () => {
    document.querySelectorAll('.platform-cb').forEach(cb => { cb.checked = false; });
  });

  // 折叠
  const inputArea = document.getElementById('input-area');
  const toggleIcon = document.getElementById('toggle-icon');
  const toggleText = document.getElementById('toggle-text');
  document.getElementById('toggle-input').addEventListener('click', () => {
    inputArea.classList.toggle('hidden');
    if (inputArea.classList.contains('hidden')) {
      toggleIcon.style.transform = 'rotate(180deg)';
      toggleText.textContent = '展开';
    } else {
      toggleIcon.style.transform = 'rotate(0deg)';
      toggleText.textContent = '收起';
    }
  });

  function scrollBottom() {
    chatArea.scrollTop = chatArea.scrollHeight;
  }

  function escapeHtml(text) {
    var div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function addUserMessage(product, platformNames, types) {
    var div = document.createElement('div');
    div.className = 'flex gap-3 max-w-2xl ml-auto flex-row-reverse';
    div.innerHTML = '<div class="w-8 h-8 rounded-full bg-gradient-to-br from-green-500 to-emerald-500 flex items-center justify-center text-white text-sm flex-shrink-0">👤</div>' +
      '<div class="bg-purple-50 rounded-2xl rounded-tr-sm px-4 py-3 border border-purple-100">' +
      '<p class="text-sm text-gray-800">' + escapeHtml(product) + '</p>' +
      '<p class="text-xs text-purple-500 mt-1">📌 ' + platformNames.join('、') + ' · ' + types.join(' + ') + '</p>' +
      '</div>';
    messagesContainer.appendChild(div);
    scrollBottom();
  }

  function addTypingIndicator() {
    var div = document.createElement('div');
    div.id = 'typing-indicator';
    div.className = 'flex gap-3 max-w-3xl';
    div.innerHTML = '<div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-500 to-indigo-500 flex items-center justify-center text-white text-sm flex-shrink-0">🤖</div>' +
      '<div class="bg-white rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm border border-gray-100">' +
      '<p class="text-sm text-gray-400">' + spinnerSVG + ' 正在批量生成...</p>' +
      '</div>';
    messagesContainer.appendChild(div);
    scrollBottom();
  }

  function removeTypingIndicator() {
    var el = document.getElementById('typing-indicator');
    if (el) el.remove();
  }

  function addResultMessage(data, product) {
    var div = document.createElement('div');
    div.className = 'flex gap-3 max-w-4xl';

    var contentHTML = '<div class="bg-white rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm border border-gray-100 flex-1 min-w-0">';
    contentHTML += '<p class="text-xs text-gray-400 mb-3">✅ 生成完成 · ' + new Date().toLocaleTimeString('zh-CN') + '</p>';

    // 文案结果
    if (data.copy && data.copy.length > 0) {
      contentHTML += '<div class="mb-4">';
      contentHTML += '<h4 class="text-sm font-medium text-gray-700 mb-2">✍️ 文案</h4>';
      data.copy.forEach(function(item, idx) {
        var pi = PLATFORMS.find(p => p.id === item.platform);
        var blockId = 'batch-copy-' + Date.now() + '-' + idx;
        contentHTML += '<div class="mb-3 bg-gray-50 rounded-xl p-3 border border-gray-100">' +
          '<div class="flex items-center justify-between mb-2">' +
          '<span class="text-xs font-medium text-gray-500">' + (pi ? pi.emoji + ' ' + pi.name : item.platform) + '</span>' +
          '<button class="batch-copy-btn px-2 py-1 rounded-lg border border-purple-200 text-purple-600 hover:bg-purple-50 text-[11px] font-medium" data-id="' + blockId + '">📋 复制</button>' +
          '</div>' +
          '<div id="' + blockId + '" class="text-sm text-gray-700 leading-relaxed whitespace-pre-wrap" style="max-height:200px;overflow-y:auto">' + escapeHtml(item.content) + '</div>' +
          '</div>';
      });
      contentHTML += '</div>';
    }

    // 配图结果
    if (data.image) {
      var imgId = 'batch-img-' + Date.now();
      contentHTML += '<div class="mb-4">' +
        '<div class="flex items-center justify-between mb-2">' +
        '<h4 class="text-sm font-medium text-gray-700">🎨 配图提示词</h4>' +
        '<button class="batch-copy-btn px-2 py-1 rounded-lg border border-purple-200 text-purple-600 hover:bg-purple-50 text-[11px] font-medium" data-id="' + imgId + '">📋 复制</button>' +
        '</div>' +
        '<div id="' + imgId + '" class="bg-gray-50 rounded-xl p-3 border border-gray-100 text-sm text-gray-700 leading-relaxed whitespace-pre-wrap" style="max-height:200px;overflow-y:auto">' + escapeHtml(data.image) + '</div>' +
        '</div>';
    }

    // 视频结果
    if (data.video) {
      var vidId = 'batch-vid-' + Date.now();
      contentHTML += '<div class="mb-3">' +
        '<div class="flex items-center justify-between mb-2">' +
        '<h4 class="text-sm font-medium text-gray-700">🎬 视频脚本</h4>' +
        '<div class="flex gap-2">' +
        '<button class="batch-copy-btn px-2 py-1 rounded-lg border border-purple-200 text-purple-600 hover:bg-purple-50 text-[11px] font-medium" data-id="' + vidId + '">📋 复制</button>' +
        '<a href="https://jimeng.jianying.com/ai-tool/image/generate" target="_blank" class="px-2 py-1 rounded-lg bg-purple-600 text-white text-[11px] font-medium hover:bg-purple-700">🎨 即梦AI</a>' +
        '</div></div>' +
        '<div id="' + vidId + '" class="bg-gray-50 rounded-xl p-3 border border-gray-100 text-sm text-gray-700 leading-relaxed whitespace-pre-wrap" style="max-height:200px;overflow-y:auto">' + escapeHtml(data.video) + '</div>' +
        '</div>';
    }

    // 操作按钮
    contentHTML += '<div class="flex gap-2 mt-3">' +
      '<a href="/publish" class="flex-1 py-2 rounded-xl bg-gradient-to-r from-green-500 to-emerald-600 text-white text-xs font-medium text-center hover:opacity-90 transition-all">📤 去发布管理</a>' +
      '<button class="continue-gen-btn px-4 py-2 rounded-xl border border-purple-200 text-purple-600 text-xs font-medium hover:bg-purple-50 transition-all">🔄 继续</button>' +
      '</div>';

    contentHTML += '</div>';
    div.innerHTML = '<div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-500 to-indigo-500 flex items-center justify-center text-white text-sm flex-shrink-0">🤖</div>' + contentHTML;

    messagesContainer.appendChild(div);
    scrollBottom();

    // 绑定复制按钮
    div.querySelectorAll('.batch-copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        var el = document.getElementById(btn.dataset.id);
        if (el) {
          navigator.clipboard.writeText(el.textContent).then(() => {
            var orig = btn.innerHTML;
            btn.innerHTML = '✅ 已复制';
            setTimeout(() => { btn.innerHTML = orig; }, 2000);
          }).catch(() => alert('复制失败'));
        }
      });
    });

    // 继续生成
    div.querySelector('.continue-gen-btn').addEventListener('click', () => {
      inputArea.classList.remove('hidden');
      toggleIcon.style.transform = 'rotate(0deg)';
      toggleText.textContent = '收起';
      chatArea.scrollTop = chatArea.scrollHeight;
    });
  }

  function addErrorMessage(msg) {
    var div = document.createElement('div');
    div.className = 'flex gap-3 max-w-2xl';
    div.innerHTML = '<div class="w-8 h-8 rounded-full bg-red-100 flex items-center justify-center text-red-500 text-sm flex-shrink-0">😢</div>' +
      '<div class="bg-red-50 rounded-2xl rounded-tl-sm px-4 py-3 border border-red-100">' +
      '<p class="text-sm text-red-600">' + escapeHtml(msg) + '</p>' +
      '</div>';
    messagesContainer.appendChild(div);
    scrollBottom();
  }

  function setLoading(loading) {
    generateBtn.disabled = loading;
    if (loading) {
      btnText.innerHTML = spinnerSVG + ' 生成中';
    } else {
      btnText.innerHTML = '🚀 生成';
    }
  }

  async function generate() {
    var product = document.getElementById('product-input').value.trim();
    if (!product) { alert('请输入产品描述'); return; }

    var platforms = Array.from(document.querySelectorAll('.platform-cb:checked')).map(cb => cb.value);
    if (platforms.length === 0) { alert('请至少选择一个平台'); return; }

    var types = {
      copy: document.getElementById('type-copy').checked,
      image: document.getElementById('type-image').checked,
      video: document.getElementById('type-video').checked,
    };
    if (!types.copy && !types.image && !types.video) { alert('请至少选择一种内容类型'); return; }

    var extra = document.getElementById('extra-input').value.trim();

    var platformNames = platforms.map(pid => {
      var p = PLATFORMS.find(x => x.id === pid);
      return p ? p.emoji + p.name : pid;
    });
    var typeLabels = [];
    if (types.copy) typeLabels.push('文案');
    if (types.image) typeLabels.push('配图');
    if (types.video) typeLabels.push('视频');

    addUserMessage(product, platformNames, typeLabels);
    document.getElementById('product-input').value = '';
    document.getElementById('extra-input').value = '';

    setLoading(true);
    addTypingIndicator();

    try {
      var requests = [];
      if (types.copy && types.video) {
        requests.push(fetch('/api/generate', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: 'batch', product, platforms, extra }),
        }));
      } else if (types.copy) {
        requests.push(fetch('/api/generate', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: 'copy', product, platforms, extra }),
        }));
      } else if (types.video) {
        requests.push(fetch('/api/generate', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: 'video', product, platforms, extra }),
        }));
      }
      if (types.image) {
        requests.push(fetch('/api/generate', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: 'image', product, platforms, extra }),
        }));
      }

      var responses = await Promise.all(requests);
      var dataList = await Promise.all(responses.map(r => r.json()));

      generatedData = { copy: [], image: '', video: '' };
      dataList.forEach(function(data) {
        if (data.success && data.results) {
          if (data.results.copy) generatedData.copy = data.results.copy;
          if (data.results.image) generatedData.image = data.results.image;
          if (data.results.video) generatedData.video = data.results.video;
        }
      });

      removeTypingIndicator();
      addResultMessage(generatedData, product);

      // 保存历史
      try {
        var history = JSON.parse(localStorage.getItem('smart_marketing_history') || '[]');
        history.push({
          id: Date.now().toString(),
          date: new Date().toISOString().slice(0, 10),
          product: product,
          platforms: platforms,
          copy: generatedData.copy,
          image: generatedData.image || '',
          video: generatedData.video || '',
        });
        localStorage.setItem('smart_marketing_history', JSON.stringify(history));
      } catch (e) { console.error('保存历史失败', e); }

    } catch (e) {
      removeTypingIndicator();
      addErrorMessage('网络错误，请重试');
    } finally {
      setLoading(false);
    }
  }

  generateBtn.addEventListener('click', generate);

  document.getElementById('product-input').addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      generate();
    }
  });

  // 接收来自文案生成的数据
  (function checkPendingData() {
    try {
      var pendingStr = localStorage.getItem('sm_pending_generate');
      if (!pendingStr) return;
      var pending = JSON.parse(pendingStr);
      if (Date.now() - pending.timestamp > 5 * 60 * 1000) {
        localStorage.removeItem('sm_pending_generate');
        return;
      }
      var productInput = document.getElementById('product-input');
      if (pending.product) productInput.value = pending.product;
      if (pending.extra) document.getElementById('extra-input').value = pending.extra;
      if (pending.sourcePlatform) {
        var cb = document.querySelector('.platform-cb[value="' + pending.sourcePlatform + '"]');
        if (cb) {
          document.querySelectorAll('.platform-cb').forEach(c => { c.checked = false; });
          cb.checked = true;
        }
      }
      var banner = document.getElementById('from-copy-banner');
      var info = document.getElementById('from-copy-info');
      banner.classList.remove('hidden');
      var pi = PLATFORMS.find(p => p.id === pending.sourcePlatform);
      info.textContent = pending.product.slice(0, 30) + (pending.product.length > 30 ? '...' : '') + (pi ? ' · 来自 ' + pi.emoji + pi.name : '');
      localStorage.removeItem('sm_pending_generate');
      document.getElementById('close-from-banner').addEventListener('click', () => {
        banner.classList.add('hidden');
      });
    } catch (e) { console.error(e); }
  })();
</script>
</Base>
