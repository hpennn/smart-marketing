---
import Base from '../layouts/Base.astro';
---

<Base title="发布管理" active="publish">
<main class="max-w-6xl mx-auto px-4 py-8">
  <!-- 顶部说明 -->
  <div class="bg-purple-50 rounded-2xl p-4 mb-6 flex items-center gap-3 border border-purple-100">
    <span class="text-2xl">💡</span>
    <p class="text-sm text-purple-700">从「<a href="/copy" class="font-medium underline">文案生成</a>」或「<a href="/generate" class="font-medium underline">批量推广</a>」生成的内容会自动保存在这里</p>
  </div>

  <!-- 油猴脚本安装提示 -->
  <div id="userscript-banner" class="bg-indigo-50 border border-indigo-200 rounded-xl p-4 mb-6 text-sm text-indigo-800 flex items-center gap-2 flex-wrap">
    💡 <strong>自动填写</strong>需要安装油猴脚本。
    <a href="https://www.tampermonkey.net/" target="_blank" class="text-indigo-700 underline">① 安装 Tampermonkey</a>
    →
    <a href="https://github.com/hpennn/smart-marketing/raw/main/auto-fill.user.js" target="_blank" class="text-indigo-700 underline font-semibold">② 安装一键填写脚本</a>
    <button onclick="document.getElementById('userscript-banner').style.display='none';localStorage.setItem('sm_hide_banner','1')" class="ml-auto bg-transparent border-none text-indigo-700 cursor-pointer text-lg leading-none">✕</button>
  </div>

  <!-- 油猴脚本安装引导弹窗 -->
  <div id="install-modal" style="display:none" class="fixed inset-0 bg-black/50 z-[9999] flex items-center justify-center">
    <div class="bg-white rounded-2xl p-7 max-w-[420px] w-[90%] shadow-2xl">
      <h3 class="text-lg font-bold text-gray-900 mb-4">🐒 安装油猴脚本，启用自动填写</h3>
      <div class="bg-gray-50 rounded-xl p-4 mb-4 space-y-3">
        <div class="flex items-start gap-3">
          <span class="w-6 h-6 rounded-full bg-purple-600 text-white flex items-center justify-center text-xs font-bold flex-shrink-0">1</span>
          <div>安装 Tampermonkey 浏览器扩展<br><a href="https://www.tampermonkey.net/" target="_blank" class="text-purple-600 text-sm">👉 点击安装 tampermonkey.net</a></div>
        </div>
        <div class="flex items-start gap-3">
          <span class="w-6 h-6 rounded-full bg-purple-600 text-white flex items-center justify-center text-xs font-bold flex-shrink-0">2</span>
          <div>安装一键填写脚本<br><a href="https://github.com/hpennn/smart-marketing/raw/main/auto-fill.user.js" target="_blank" class="text-purple-600 text-sm">👉 点击安装脚本</a></div>
        </div>
        <div class="flex items-start gap-3">
          <span class="w-6 h-6 rounded-full bg-purple-600 text-white flex items-center justify-center text-xs font-bold flex-shrink-0">3</span>
          <div>完成后回来点击「一键填写」即可自动填入 ✨</div>
        </div>
      </div>
      <div class="flex gap-3">
        <button onclick="closeInstallModal()" class="flex-1 py-2.5 rounded-xl border border-gray-200 text-gray-500 text-sm cursor-pointer">我知道了</button>
        <button onclick="closeInstallModal(true)" class="flex-1 py-2.5 rounded-xl border-none bg-gradient-to-r from-purple-600 to-indigo-600 text-white text-sm font-semibold cursor-pointer">不再提示</button>
      </div>
    </div>
  </div>

  <!-- 新内容到达提示 -->
  <div id="new-content-banner" class="hidden bg-gradient-to-r from-green-50 to-emerald-50 border border-green-200 rounded-xl p-4 mb-5 flex items-center gap-3">
    <span class="text-xl">🎉</span>
    <div class="flex-1">
      <p class="text-sm font-semibold text-green-800">新内容已就绪！</p>
      <p class="text-xs text-green-600 mt-0.5">刚刚从批量推广生成的内容已保存在下方</p>
    </div>
    <button onclick="document.getElementById('new-content-banner').classList.add('hidden')" class="text-green-600 hover:text-green-800 text-lg font-bold">✕</button>
  </div>

  <!-- 内容列表 -->
  <div id="history-list" class="space-y-6"></div>

  <!-- Toast 提示 -->
  <div id="publish-toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 bg-gray-800 text-white px-6 py-3 rounded-xl shadow-lg opacity-0 transition-all duration-300 pointer-events-none z-50"></div>

  <!-- 空状态 -->
  <div id="empty-state" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-12 flex flex-col items-center justify-center text-gray-400">
    <div class="text-6xl mb-4">📭</div>
    <p class="text-lg font-medium">还没有生成的内容</p>
    <p class="text-sm mt-1 mb-6">去生成一些推广内容吧，生成后会自动保存在这里</p>
    <div class="flex gap-3">
      <a href="/copy" class="px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-600 to-indigo-600 text-white text-sm font-medium hover:from-purple-700 hover:to-indigo-700 transition-all">
        ✍️ 文案生成
      </a>
      <a href="/generate" class="px-5 py-2.5 rounded-xl border border-purple-200 text-purple-600 text-sm font-medium hover:bg-purple-50 transition-all">
        🚀 批量推广
      </a>
    </div>
  </div>
</main>

<script>
  // ========== 工具函数 ==========
  function showToast(msg: string) {
    const toast = document.getElementById('publish-toast');
    if (toast) {
      toast.textContent = msg;
      toast.classList.remove('opacity-0');
      toast.classList.add('opacity-100');
      setTimeout(() => {
        toast.classList.remove('opacity-100');
        toast.classList.add('opacity-0');
      }, 3000);
    }
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function copyText(text: string, btn?: HTMLElement) {
    navigator.clipboard.writeText(text).then(() => {
      if (btn) {
        const orig = btn.innerHTML;
        btn.innerHTML = '✅ 已复制';
        setTimeout(() => { btn.innerHTML = orig; }, 2000);
      }
    }).catch(() => showToast('❌ 复制失败'));
  }

  // ========== 平台配置 ==========
  const PLATFORMS: Record<string, { name: string; emoji: string }> = {
    xiaohongshu: { name: '小红书', emoji: '📕' },
    zhihu: { name: '知乎', emoji: '📘' },
    wechat: { name: '微信公众号', emoji: '💬' },
    douyin: { name: '抖音', emoji: '🎵' },
    bilibili: { name: '哔哩哔哩', emoji: '📺' },
    weibo: { name: '微博', emoji: '📢' },
    qywechat: { name: '企业微信', emoji: '👥' },
    toutiao: { name: '头条号', emoji: '🔥' },
    jike: { name: '即刻', emoji: '📌' },
  };

  const PUBLISH_LINKS: Record<string, { name: string; url: string }> = {
    xiaohongshu: { name: '小红书', url: 'https://creator.xiaohongshu.com/publish/publish' },
    zhihu: { name: '知乎', url: 'https://www.zhihu.com/creator' },
    wechat: { name: '微信公众号', url: 'https://mp.weixin.qq.com/' },
    douyin: { name: '抖音', url: 'https://creator.douyin.com/creator-micro/content/upload' },
    bilibili: { name: '哔哩哔哩', url: 'https://member.bilibili.com/platform/upload/text' },
    weibo: { name: '微博', url: 'https://weibo.com' },
    toutiao: { name: '头条号', url: 'https://mp.toutiao.com/' },
    jike: { name: '即刻', url: 'https://web.okjike.com/' },
  };

  // ========== 一键填写 ==========
  function oneClickFill(title: string, content: string, platformKey: string) {
    const PLATFORM_URLS: Record<string, string> = {
      xiaohongshu: 'https://creator.xiaohongshu.com/publish/publish',
      zhihu: 'https://www.zhihu.com/creator',
      wechat: 'https://mp.weixin.qq.com/',
      douyin: 'https://creator.douyin.com/creator-micro/content/upload',
      bilibili: 'https://member.bilibili.com/platform/upload-text',
      weibo: 'https://service.weibo.com/share/share.php',
      toutiao: 'https://mp.toutiao.com/profile_v4/graphic/publish',
      jike: 'https://web.okjike.com/',
      qywechat: 'https://work.weixin.qq.com/'
    };
    const url = PLATFORM_URLS[platformKey];
    if (!url) { showToast('❌ 未找到平台'); return; }

    navigator.clipboard.writeText(content).catch(() => {});

    if (platformKey === 'weibo') {
      const shareUrl = url + '?title=' + encodeURIComponent((title ? title + '\n\n' : '') + content);
      window.open(shareUrl, '_blank');
      showToast('✅ 微博内容已预填');
      return;
    }

    const payload = JSON.stringify({ title: title || '', content: content });
    const fullUrl = url + '#smfill=' + encodeURIComponent(payload);

    if (fullUrl.length > 1800) {
      window.open(url, '_blank');
      showToast('📋 内容过长已复制，请在平台页面 Ctrl+V 粘贴');
      return;
    }

    window.open(fullUrl, '_blank');
    showToast('✅ 正在打开平台，内容将自动填入（需安装油猴脚本）');
  }

  // ========== 数据存取 ==========
  let historyCache: any[] = [];

  function loadHistory(): any[] {
    try {
      return JSON.parse(localStorage.getItem('smart_marketing_history') || '[]');
    } catch (e) {
      return [];
    }
  }

  function saveHistory(history: any[]) {
    try {
      localStorage.setItem('smart_marketing_history', JSON.stringify(history));
    } catch (e) {
      console.error('保存失败', e);
    }
  }

  // 获取某平台的视频脚本（兼容旧字符串格式和新数组格式）
  function getVideoForPlatform(item: any, platformId: string): string {
    if (!item.video) return '';
    // 新格式：数组 [{platform, content}]
    if (Array.isArray(item.video)) {
      const found = item.video.find((v: any) => v.platform === platformId);
      return found?.content || '';
    }
    // 旧格式：单一字符串，所有平台共用
    return item.video;
  }

  // ========== 渲染历史 ==========
  function renderHistory() {
    historyCache = loadHistory();
    const listEl = document.getElementById('history-list')!;
    const emptyEl = document.getElementById('empty-state')!;

    if (historyCache.length === 0) {
      listEl.innerHTML = '';
      emptyEl.classList.remove('hidden');
      return;
    }

    emptyEl.classList.add('hidden');
    listEl.innerHTML = '';

    historyCache.forEach((item: any, index: number) => {
      // 外层卡片：一条历史记录
      const card = document.createElement('div');
      card.className = 'bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden';
      card.dataset.index = index.toString();

      const hasCopy = item.copy && item.copy.length > 0;
      const hasImage = item.image && item.image.trim();
      // 检查是否有视频内容
      let hasVideo = false;
      if (item.video) {
        if (typeof item.video === 'string' && item.video.trim()) hasVideo = true;
        if (Array.isArray(item.video) && item.video.length > 0) hasVideo = true;
      }

      // === 卡片头部 ===
      const headerHtml = `
        <div class="px-5 pt-5 pb-3">
          <div class="flex items-start justify-between">
            <div>
              <span class="text-xs text-gray-400">${item.date || ''}</span>
              <h3 class="font-semibold text-gray-900 mt-0.5">${escapeHtml(item.product || '未命名产品')}</h3>
            </div>
            <div class="flex items-center gap-2">
              <button class="copy-all-card-btn px-3 py-1.5 rounded-lg border border-purple-200 text-purple-600 hover:bg-purple-50 transition-all text-xs font-medium">📋 复制全部</button>
              <button class="delete-btn text-gray-400 hover:text-red-500 transition-colors p-1" data-card-index="${index}" title="删除">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3"/></svg>
              </button>
            </div>
          </div>
          <div class="flex flex-wrap gap-1.5 mt-2">
            ${(item.platforms || []).map((pid: string) => {
              const p = PLATFORMS[pid];
              return p ? `<span class="text-xs bg-purple-50 text-purple-600 px-2 py-0.5 rounded-full">${p.emoji} ${p.name}</span>` : '';
            }).join('')}
          </div>
        </div>
      `;

      // === 按平台分组内容区 ===
      let platformsHtml = '<div class="px-5 pb-4 space-y-3">';

      // 获取该平台列表（从 copy 中提取，或从 platforms 字段）
      const platformIds: string[] = [];
      if (hasCopy) {
        item.copy.forEach((c: any) => {
          if (c.platform && !platformIds.includes(c.platform)) platformIds.push(c.platform);
        });
      }
      if (platformIds.length === 0 && item.platforms) {
        platformIds.push(...item.platforms);
      }

      platformIds.forEach((pid: string) => {
        const p = PLATFORMS[pid] || { name: pid, emoji: '📄' };
        const copyItem = hasCopy ? item.copy.find((c: any) => c.platform === pid) : null;
        const videoContent = getVideoForPlatform(item, pid);

        platformsHtml += `
          <div class="rounded-xl border border-gray-200 overflow-hidden" data-platform-id="${pid}">
            <!-- 平台标题栏 -->
            <div class="px-4 py-2.5 bg-gradient-to-r from-gray-50 to-white border-b border-gray-100 flex items-center justify-between">
              <span class="text-sm font-semibold text-gray-800 flex items-center gap-1.5">
                <span class="text-lg">${p.emoji}</span> ${p.name}
              </span>
              <div class="flex items-center gap-2">
                <button class="pub-oneclick-btn px-3 py-1.5 bg-gradient-to-r from-purple-600 to-indigo-600 text-white rounded-lg text-xs font-medium hover:opacity-90 transition" data-card-index="${index}" data-platform-key="${pid}">
                  ⚡ 一键填写
                </button>
                <a href="${PUBLISH_LINKS[pid]?.url || '#'}" target="_blank" rel="noopener" class="px-3 py-1.5 rounded-lg border border-gray-200 text-gray-600 hover:border-purple-300 hover:text-purple-600 transition-all text-xs font-medium">
                  打开${p.name} →
                </a>
              </div>
            </div>

            <div class="p-4 space-y-2">
        `;

        // 文案区域
        if (copyItem && copyItem.content) {
          const charCount = copyItem.content.length;
          platformsHtml += `
            <div class="rounded-lg border border-blue-100 bg-blue-50/30 overflow-hidden">
              <div class="px-3 py-2 flex items-center justify-between">
                <span class="text-xs font-medium text-blue-800 flex items-center gap-1">✍️ 文案 <span class="text-xs font-normal text-blue-500 bg-blue-100 px-1.5 py-0.5 rounded-full">${charCount} 字</span></span>
                <button class="pub-copy-btn px-2 py-0.5 rounded border border-blue-200 text-blue-600 hover:bg-blue-100 transition-all text-xs" data-card-index="${index}" data-copy-type="copy" data-copy-platform="${pid}">📋 复制</button>
              </div>
              <div class="px-3 pb-3 whitespace-pre-wrap text-gray-700 text-sm leading-relaxed bg-white rounded-b-lg border-t border-blue-100 p-2.5" style="max-height:250px;overflow-y:auto;">${escapeHtml(copyItem.content)}</div>
            </div>
          `;
        }

        // 配图区域（折叠）
        if (hasImage) {
          platformsHtml += `
            <div class="rounded-lg border border-amber-100 bg-amber-50/30 overflow-hidden">
              <button class="collapsible-toggle w-full px-3 py-2 flex items-center justify-between text-left hover:bg-amber-50/50 transition-all">
                <span class="text-xs font-medium text-amber-800">🎨 配图提示词</span>
                <span class="flex items-center gap-1.5">
                  <button class="pub-copy-btn px-2 py-0.5 rounded border border-amber-200 text-amber-600 hover:bg-amber-100 transition-all text-xs" data-card-index="${index}" data-copy-type="image">📋 复制</button>
                  <svg class="collapsible-icon w-3.5 h-3.5 text-amber-600 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </span>
              </button>
              <div class="collapsible-content hidden px-3 pb-3">
                <div class="whitespace-pre-wrap text-gray-700 text-sm leading-relaxed bg-white rounded-b-lg border-t border-amber-100 p-2.5" style="max-height:200px;overflow-y:auto;">${escapeHtml(item.image)}</div>
              </div>
            </div>
          `;
        }

        // 视频区域（折叠）
        if (hasVideo && videoContent) {
          platformsHtml += `
            <div class="rounded-lg border border-violet-100 bg-violet-50/30 overflow-hidden">
              <button class="collapsible-toggle w-full px-3 py-2 flex items-center justify-between text-left hover:bg-violet-50/50 transition-all">
                <span class="text-xs font-medium text-violet-800">🎬 视频脚本</span>
                <span class="flex items-center gap-1.5">
                  <button class="pub-copy-btn px-2 py-0.5 rounded border border-violet-200 text-violet-600 hover:bg-violet-100 transition-all text-xs" data-card-index="${index}" data-copy-type="video" data-copy-platform="${pid}">📋 复制</button>
                  <svg class="collapsible-icon w-3.5 h-3.5 text-violet-600 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </span>
              </button>
              <div class="collapsible-content hidden px-3 pb-3">
                <div class="whitespace-pre-wrap text-gray-700 text-sm leading-relaxed bg-white rounded-b-lg border-t border-violet-100 p-2.5 mb-2" style="max-height:200px;overflow-y:auto;">${escapeHtml(videoContent)}</div>
                <div class="flex gap-2 justify-end">
                  <a href="https://www.doubao.com" target="_blank" rel="noopener" class="px-2.5 py-1 rounded-lg bg-gradient-to-r from-blue-500 to-indigo-500 text-white text-xs font-medium hover:from-blue-600 hover:to-indigo-600 transition-all">🤖 豆包</a>
                  <a href="https://www.jianying.com" target="_blank" rel="noopener" class="px-2.5 py-1 rounded-lg bg-gradient-to-r from-purple-500 to-pink-500 text-white text-xs font-medium hover:from-purple-600 hover:to-pink-600 transition-all">🎬 剪映</a>
                </div>
              </div>
            </div>
          `;
        }

        platformsHtml += `
            </div>
          </div>
        `;
      });

      platformsHtml += '</div>';

      card.innerHTML = headerHtml + platformsHtml;
      listEl.appendChild(card);
    });

    // ========== 事件绑定 ==========

    // 折叠/展开
    document.querySelectorAll('.collapsible-toggle').forEach(toggle => {
      toggle.addEventListener('click', function(e) {
        if ((e.target as HTMLElement).closest('.pub-copy-btn')) return;
        const content = (this as HTMLElement).querySelector('.collapsible-content')!;
        const icon = (this as HTMLElement).querySelector('.collapsible-icon')!;
        content.classList.toggle('hidden');
        icon.style.transform = content.classList.contains('hidden') ? 'rotate(0deg)' : 'rotate(180deg)';
      });
    });

    // 复制按钮
    document.querySelectorAll('.pub-copy-btn').forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        const el = btn as HTMLElement;
        const cardIndex = parseInt(el.dataset.cardIndex!);
        const copyType = el.dataset.copyType!;
        const copyPlatform = el.dataset.copyPlatform;
        const item = historyCache[cardIndex];
        if (!item) return;

        let content = '';
        if (copyType === 'copy' && copyPlatform) {
          const c = item.copy?.find((x: any) => x.platform === copyPlatform);
          content = c?.content || '';
        } else if (copyType === 'image') {
          content = item.image || '';
        } else if (copyType === 'video') {
          content = copyPlatform ? getVideoForPlatform(item, copyPlatform) : (item.video || '');
        }
        if (content) copyText(content, btn as HTMLElement);
      });
    });

    // 复制全部（单卡片）
    document.querySelectorAll('.copy-all-card-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const cardEl = (btn as HTMLElement).closest('[data-index]') as HTMLElement;
        const idx = parseInt(cardEl.dataset.index!);
        const item = historyCache[idx];
        if (!item) return;

        let allText = `【${item.product || '未命名产品'}】\n`;
        if (item.copy && item.copy.length > 0) {
          item.copy.forEach((c: any) => {
            const p = PLATFORMS[c.platform];
            allText += `\n${'='.repeat(30)}\n${p?.emoji || ''} ${p?.name || c.platform}\n${'='.repeat(30)}\n`;
            allText += `【文案】\n${c.content}\n`;
          });
        }
        if (item.image) allText += `\n【配图提示词】\n${item.image}\n`;
        if (item.video) {
          if (Array.isArray(item.video)) {
            item.video.forEach((v: any) => {
              const p = PLATFORMS[v.platform];
              allText += `\n【${p?.name || v.platform} 视频脚本】\n${v.content}\n`;
            });
          } else {
            allText += `\n【视频脚本】\n${item.video}\n`;
          }
        }
        copyText(allText, btn as HTMLElement);
      });
    });

    // 一键填写按钮
    document.querySelectorAll('.pub-oneclick-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        const cardIndex = parseInt(el.dataset.cardIndex!);
        const platformKey = el.dataset.platformKey!;
        const item = historyCache[cardIndex];
        if (!item) return;

        const copyItem = item.copy?.find((c: any) => c.platform === platformKey);
        const title = copyItem?.title || item.product || '';
        const content = copyItem?.content || '';
        if (!content) { showToast('❌ 没有可填写的文案'); return; }

        oneClickFill(title, content, platformKey);
        const orig = btn.innerHTML;
        btn.innerHTML = '✅ 已打开';
        setTimeout(() => { btn.innerHTML = orig; }, 2000);
      });
    });

    // 删除按钮
    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const cardIndex = parseInt((btn as HTMLElement).dataset.cardIndex!);
        if (!confirm('确定要删除这条记录吗？')) return;
        const history = loadHistory();
        history.splice(cardIndex, 1);
        saveHistory(history);
        renderHistory();
      });
    });
  }

  // ========== 油猴脚本弹窗 ==========
  function showInstallModal() {
    document.getElementById('install-modal')!.style.display = 'flex';
  }
  function closeInstallModal(dontShowAgain?: boolean) {
    document.getElementById('install-modal')!.style.display = 'none';
    if (dontShowAgain) localStorage.setItem('sm_script_installed', '1');
  }
  document.querySelectorAll('.pub-oneclick-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      if (!localStorage.getItem('sm_script_installed')) {
        const platformKey = (btn as HTMLElement).dataset.platformKey || '';
        if (platformKey !== 'weibo') showInstallModal();
      }
    }, true);
  });
  if (localStorage.getItem('sm_hide_banner') === '1') {
    const b = document.getElementById('userscript-banner');
    if (b) b.style.display = 'none';
  }

  // ========== 初始化 ==========
  renderHistory();

  // 检测新内容
  (function checkNewContent() {
    const history = loadHistory();
    if (history.length === 0) return;
    const latest = history[history.length - 1];
    if (latest.id) {
      const age = Date.now() - parseInt(latest.id);
      if (age < 2 * 60 * 1000 && age > 0) {
        document.getElementById('new-content-banner')!.classList.remove('hidden');
        document.getElementById('history-list')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
  })();
</script>
</Base>
