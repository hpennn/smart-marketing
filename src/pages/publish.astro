---
import Base from '../layouts/Base.astro';
---

<Base title="发布管理" active="publish">
<main class="flex flex-col h-[calc(100vh-3.5rem)] md:h-screen">
  <!-- 对话消息区域 -->
  <div id="chat-area" class="flex-1 overflow-y-auto px-4 py-6 space-y-4">
    <!-- 欢迎消息 -->
    <div class="flex gap-3 max-w-3xl">
      <div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-500 to-indigo-500 flex items-center justify-center text-white text-sm flex-shrink-0">🤖</div>
      <div class="bg-white rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm border border-gray-100">
        <p class="text-sm text-gray-700">发布管理助手 📢</p>
        <p class="text-sm text-gray-500 mt-1">这里是你生成的所有内容，可以直接复制或跳转到平台发布。从<a href="/copy" class="text-purple-600 underline">文案生成</a>或<a href="/generate" class="text-purple-600 underline">批量推广</a>生成的内容会自动保存在这里。</p>
      </div>
    </div>

    <!-- 油猴脚本提示 -->
    <div id="userscript-banner" class="bg-indigo-50 border border-indigo-200 rounded-xl p-3 text-xs text-indigo-800 flex items-center gap-2 flex-wrap max-w-3xl">
      💡 <strong>自动填写</strong>需要安装油猴脚本。
      <a href="https://www.tampermonkey.net/" target="_blank" class="text-indigo-700 underline">① Tampermonkey</a>
      →
      <a href="https://github.com/hpennn/smart-marketing/raw/main/auto-fill.user.js" target="_blank" class="text-indigo-700 underline font-semibold">② 填写脚本</a>
      <button onclick="document.getElementById('userscript-banner').style.display='none';localStorage.setItem('sm_hide_banner','1')" class="ml-auto bg-transparent border-none text-indigo-700 cursor-pointer text-sm leading-none">✕</button>
    </div>

    <!-- 油猴安装弹窗 -->
    <div id="install-modal" style="display:none" class="fixed inset-0 bg-black/50 z-[9999] flex items-center justify-center">
      <div class="bg-white rounded-2xl p-6 max-w-[400px] w-[90%] shadow-2xl">
        <h3 class="text-base font-bold text-gray-900 mb-3">🐒 安装油猴脚本</h3>
        <div class="bg-gray-50 rounded-xl p-4 mb-4 space-y-2.5 text-sm">
          <div class="flex items-start gap-2">
            <span class="w-5 h-5 rounded-full bg-purple-600 text-white flex items-center justify-center text-[10px] font-bold flex-shrink-0">1</span>
            <div>安装 Tampermonkey<br><a href="https://www.tampermonkey.net/" target="_blank" class="text-purple-600 text-xs">👉 安装扩展</a></div>
          </div>
          <div class="flex items-start gap-2">
            <span class="w-5 h-5 rounded-full bg-purple-600 text-white flex items-center justify-center text-[10px] font-bold flex-shrink-0">2</span>
            <div>安装填写脚本<br><a href="https://github.com/hpennn/smart-marketing/raw/main/auto-fill.user.js" target="_blank" class="text-purple-600 text-xs">👉 安装脚本</a></div>
          </div>
        </div>
        <div class="flex gap-2">
          <button onclick="closeInstallModal()" class="flex-1 py-2 rounded-xl border border-gray-200 text-gray-500 text-sm cursor-pointer bg-transparent">知道了</button>
          <button onclick="closeInstallModal(true)" class="flex-1 py-2 rounded-xl border-none bg-gradient-to-r from-purple-600 to-indigo-600 text-white text-sm font-semibold cursor-pointer">不再提示</button>
        </div>
      </div>
    </div>

    <!-- 新内容提示 -->
    <div id="new-content-banner" class="hidden bg-gradient-to-r from-green-50 to-emerald-50 border border-green-200 rounded-xl p-3 flex items-center gap-2 max-w-2xl">
      <span class="text-base">🎉</span>
      <div class="flex-1">
        <p class="text-xs font-semibold text-green-800">新内容已就绪！</p>
        <p class="text-[11px] text-green-600">刚刚生成的内容已保存在下方</p>
      </div>
      <button onclick="document.getElementById('new-content-banner').classList.add('hidden')" class="text-green-600 text-sm font-bold bg-transparent border-none cursor-pointer">✕</button>
    </div>

    <!-- 内容列表 -->
    <div id="history-list" class="space-y-4"></div>

    <!-- 空状态 -->
    <div id="empty-state" class="max-w-md">
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 flex flex-col items-center text-gray-400">
        <div class="text-5xl mb-3">📭</div>
        <p class="text-base font-medium">还没有生成的内容</p>
        <p class="text-sm mt-1 mb-4 text-center">去生成一些推广内容吧</p>
        <div class="flex gap-2">
          <a href="/copy" class="px-4 py-2 rounded-xl bg-gradient-to-r from-purple-600 to-indigo-600 text-white text-sm font-medium hover:opacity-90 transition-all">✍️ 文案生成</a>
          <a href="/generate" class="px-4 py-2 rounded-xl border border-purple-200 text-purple-600 text-sm font-medium hover:bg-purple-50 transition-all">🚀 批量推广</a>
        </div>
      </div>
    </div>
  </div>
</main>

<!-- Toast -->
<div id="publish-toast" class="fixed bottom-20 md:bottom-6 left-1/2 -translate-x-1/2 bg-gray-800 text-white px-6 py-3 rounded-xl shadow-lg opacity-0 transition-all duration-300 pointer-events-none z-50"></div>

<script>
  function escapeHtml(text) {
    var div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function showToast(msg) {
    var toast = document.getElementById('publish-toast');
    if (toast) {
      toast.textContent = msg;
      toast.classList.remove('opacity-0');
      toast.classList.add('opacity-100');
      setTimeout(function() {
        toast.classList.remove('opacity-100');
        toast.classList.add('opacity-0');
      }, 3000);
    }
  }

  var PLATFORMS = {
    xiaohongshu: { name: '小红书', emoji: '📕' },
    zhihu: { name: '知乎', emoji: '📘' },
    wechat: { name: '微信公众号', emoji: '💬' },
    douyin: { name: '抖音', emoji: '🎵' },
    bilibili: { name: '哔哩哔哩', emoji: '📺' },
    weibo: { name: '微博', emoji: '📢' },
    qywechat: { name: '企业微信', emoji: '👥' },
    toutiao: { name: '头条号', emoji: '🔥' },
    jike: { name: '即刻', emoji: '📌' },
  };

  var PUBLISH_LINKS = {
    xiaohongshu: { name: '小红书', url: 'https://creator.xiaohongshu.com/publish/publish' },
    zhihu: { name: '知乎', url: 'https://www.zhihu.com/creator' },
    wechat: { name: '微信公众号', url: 'https://mp.weixin.qq.com/' },
    douyin: { name: '抖音', url: 'https://creator.douyin.com/creator-micro/content/upload' },
    bilibili: { name: '哔哩哔哩', url: 'https://member.bilibili.com/platform/upload/text' },
    weibo: { name: '微博', url: 'https://weibo.com' },
    toutiao: { name: '头条号', url: 'https://mp.toutiao.com/' },
    jike: { name: '即刻', url: 'https://web.okjike.com/' },
  };

  var historyCache = [];

  function loadHistory() {
    try { return JSON.parse(localStorage.getItem('smart_marketing_history') || '[]'); }
    catch (e) { return []; }
  }

  function saveHistory(history) {
    try { localStorage.setItem('smart_marketing_history', JSON.stringify(history)); }
    catch (e) { console.error('保存失败', e); }
  }

  function oneClickFill(title, content, platformKey) {
    var PLATFORM_URLS = {
      xiaohongshu: 'https://creator.xiaohongshu.com/publish/publish',
      zhihu: 'https://www.zhihu.com/creator',
      wechat: 'https://mp.weixin.qq.com/',
      douyin: 'https://creator.douyin.com/creator-micro/content/upload',
      bilibili: 'https://member.bilibili.com/platform/upload-text',
      weibo: 'https://service.weibo.com/share/share.php',
      toutiao: 'https://mp.toutiao.com/profile_v4/graphic/publish',
      jike: 'https://web.okjike.com/',
      qywechat: 'https://work.weixin.qq.com/'
    };
    var url = PLATFORM_URLS[platformKey];
    if (!url) { showToast('❌ 未找到平台'); return; }
    navigator.clipboard.writeText(content).catch(function(){});

    if (platformKey === 'weibo') {
      var shareUrl = url + '?title=' + encodeURIComponent((title ? title + '\n\n' : '') + content);
      window.open(shareUrl, '_blank');
      showToast('✅ 微博内容已预填');
      return;
    }

    var payload = JSON.stringify({ title: title || '', content: content });
    var fullUrl = url + '#smfill=' + encodeURIComponent(payload);
    if (fullUrl.length > 1800) {
      window.open(url, '_blank');
      showToast('📋 内容过长已复制，请 Ctrl+V 粘贴');
      return;
    }
    window.open(fullUrl, '_blank');
    showToast('✅ 正在打开平台，内容将自动填入');
  }

  function renderHistory() {
    historyCache = loadHistory();
    var listEl = document.getElementById('history-list');
    var emptyEl = document.getElementById('empty-state');

    if (historyCache.length === 0) {
      listEl.innerHTML = '';
      emptyEl.classList.remove('hidden');
      return;
    }

    emptyEl.classList.add('hidden');
    listEl.innerHTML = '';

    historyCache.forEach(function(item, index) {
      var card = document.createElement('div');
      card.className = 'max-w-3xl';
      card.dataset.index = index.toString();

      var platformTags = (item.platforms || []).map(function(pid) {
        var p = PLATFORMS[pid];
        return p ? '<span class="text-[11px] bg-purple-50 text-purple-600 px-2 py-0.5 rounded-full">' + p.emoji + ' ' + p.name + '</span>' : '';
      }).join('');

      var hasCopy = item.copy && item.copy.length > 0;
      var hasImage = item.image && item.image.trim();
      var hasVideo = item.video && item.video.trim();
      var tabs = [];
      if (hasCopy) tabs.push('copy');
      if (hasImage) tabs.push('image');
      if (hasVideo) tabs.push('video');

      var tabLabels = { copy: '✍️ 文案', image: '🎨 配图', video: '🎬 视频' };

      // 发布链接
      var publishLinks = (item.platforms || [])
        .filter(function(pid) { return PUBLISH_LINKS[pid]; })
        .map(function(pid) {
          var link = PUBLISH_LINKS[pid];
          var p = PLATFORMS[pid];
          return '<a href="' + link.url + '" target="_blank" rel="noopener" class="px-2.5 py-1 rounded-lg border border-gray-200 text-gray-600 hover:border-purple-300 hover:text-purple-600 transition-all text-[11px] font-medium inline-flex items-center gap-1">' +
            (p ? p.emoji : '') + ' ' + link.name + ' →</a>';
        }).join('');

      var tabButtons = tabs.map(function(t, i) {
        return '<button class="pub-tab-btn flex-1 py-2 text-xs font-medium transition-all border-b-2 ' +
          (i === 0 ? 'border-purple-600 text-purple-600' : 'border-transparent text-gray-500 hover:text-gray-700') +
          '" data-tab="' + t + '" data-card-index="' + index + '">' + tabLabels[t] + '</button>';
      }).join('');

      var tabPanels = tabs.map(function(t, i) {
        var content = '';
        if (t === 'copy') {
          var copyItems = item.copy.map(function(c, ci) {
            var p = PLATFORMS[c.platform];
            return '<div class="border-b border-gray-100 last:border-0 pb-2 mb-2 last:pb-0 last:mb-0">' +
              '<div class="flex items-center justify-between mb-1.5">' +
              '<span class="text-[11px] font-medium text-gray-500">' + (p ? p.emoji + ' ' + p.name : c.platform) + '</span>' +
              '<div class="flex items-center gap-1.5">' +
              '<button class="pub-copy-btn px-2 py-1 rounded-lg border border-purple-200 text-purple-600 hover:bg-purple-50 text-[11px] font-medium" data-card-index="' + index + '" data-copy-type="copy" data-copy-sub="' + ci + '">📋 复制</button>' +
              '<button class="pub-oneclick-btn px-2.5 py-1 bg-gradient-to-r from-purple-600 to-indigo-600 text-white rounded-lg text-[11px] font-medium hover:opacity-90 transition" data-card-index="' + index + '" data-copy-sub="' + ci + '" data-platform-key="' + c.platform + '">⚡ 一键填写</button>' +
              '</div></div>' +
              '<div class="text-gray-700 text-sm leading-relaxed whitespace-pre-wrap">' + escapeHtml(c.content) + '</div>' +
              '</div>';
          }).join('');
          content = '<div class="overflow-y-auto" style="max-height:300px">' + copyItems + '</div>';
        } else if (t === 'image') {
          content = '<div class="flex items-center justify-between mb-2">' +
            '<span class="text-[11px] text-gray-400">AI配图提示词</span>' +
            '<div class="flex items-center gap-1.5">' +
            '<button class="pub-copy-btn px-2 py-1 rounded-lg border border-purple-200 text-purple-600 hover:bg-purple-50 text-[11px] font-medium" data-card-index="' + index + '" data-copy-type="image">📋 复制</button>' +
            '<button class="pub-oneclick-btn px-2.5 py-1 bg-gradient-to-r from-purple-600 to-indigo-600 text-white rounded-lg text-[11px] font-medium hover:opacity-90 transition" data-card-index="' + index + '" data-copy-type="image" data-platform-key="xiaohongshu">⚡ 填写</button>' +
            '</div></div>' +
            '<div class="text-gray-700 text-sm leading-relaxed whitespace-pre-wrap bg-gray-50 rounded-xl p-3 overflow-y-auto" style="max-height:300px">' + escapeHtml(item.image) + '</div>';
        } else if (t === 'video') {
          content = '<div class="flex items-center justify-between mb-2">' +
            '<span class="text-[11px] text-gray-400">视频脚本</span>' +
            '<div class="flex items-center gap-1.5">' +
            '<button class="pub-copy-btn px-2 py-1 rounded-lg border border-purple-200 text-purple-600 hover:bg-purple-50 text-[11px] font-medium" data-card-index="' + index + '" data-copy-type="video">📋 复制</button>' +
            '<button class="pub-oneclick-btn px-2.5 py-1 bg-gradient-to-r from-purple-600 to-indigo-600 text-white rounded-lg text-[11px] font-medium hover:opacity-90 transition" data-card-index="' + index + '" data-copy-type="video" data-platform-key="douyin">⚡ 填写</button>' +
            '</div></div>' +
            '<div class="text-gray-700 text-sm leading-relaxed whitespace-pre-wrap bg-gray-50 rounded-xl p-3 overflow-y-auto" style="max-height:300px">' + escapeHtml(item.video) + '</div>';
        }
        return '<div class="pub-tab-panel p-3 ' + (i === 0 ? '' : 'hidden') + '" data-tab="' + t + '" data-card-index="' + index + '">' + content + '</div>';
      }).join('');

      card.innerHTML =
        '<!-- AI 头像 + 消息气泡 -->' +
        '<div class="flex gap-3">' +
        '<div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-500 to-indigo-500 flex items-center justify-center text-white text-sm flex-shrink-0 mt-1">🤖</div>' +
        '<div class="bg-white rounded-2xl rounded-tl-sm shadow-sm border border-gray-100 overflow-hidden flex-1 min-w-0">' +
        '<div class="px-4 pt-4 pb-2">' +
        '<div class="flex items-start justify-between">' +
        '<div>' +
        '<div class="flex items-center gap-2 mb-1"><span class="text-[11px] text-gray-400">' + (item.date || '') + '</span></div>' +
        '<h3 class="font-semibold text-gray-900 text-sm">' + escapeHtml(item.product || '未命名产品') + '</h3>' +
        '</div>' +
        '<button class="delete-btn text-gray-400 hover:text-red-500 transition-colors p-1 bg-transparent border-none cursor-pointer" data-card-index="' + index + '" title="删除">' +
        '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3"/></svg>' +
        '</button></div>' +
        '<div class="flex flex-wrap gap-1 mt-1.5">' + platformTags + '</div>' +
        '</div>' +
        (tabs.length > 0 ? '<div class="border-t border-gray-100"><div class="flex">' + tabButtons + '</div>' + tabPanels + '</div>' : '') +
        (publishLinks ? '<div class="px-4 py-3 bg-gray-50 border-t border-gray-100"><p class="text-[11px] text-gray-400 mb-1.5">跳转发布</p><div class="flex flex-wrap gap-1.5">' + publishLinks + '</div></div>' : '') +
        '</div></div>';

      listEl.appendChild(card);
    });

    // 绑定 Tab 切换
    document.querySelectorAll('.pub-tab-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var tab = btn.dataset.tab;
        var cardIndex = btn.dataset.cardIndex;
        var card = document.querySelector('[data-index="' + cardIndex + '"]');
        if (!card) return;

        card.querySelectorAll('.pub-tab-btn').forEach(function(b) {
          b.classList.remove('border-purple-600', 'text-purple-600');
          b.classList.add('border-transparent', 'text-gray-500');
        });
        btn.classList.add('border-purple-600', 'text-purple-600');
        btn.classList.remove('border-transparent', 'text-gray-500');

        card.querySelectorAll('.pub-tab-panel').forEach(function(panel) {
          if (panel.dataset.tab === tab) panel.classList.remove('hidden');
          else panel.classList.add('hidden');
        });
      });
    });

    // 绑定复制按钮
    document.querySelectorAll('.pub-copy-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var cardIndex = parseInt(btn.dataset.cardIndex);
        var copyType = btn.dataset.copyType;
        var copySub = btn.dataset.copySub;
        var item = historyCache[cardIndex];
        if (!item) return;

        var content = '';
        if (copyType === 'copy' && copySub !== undefined) {
          content = (item.copy && item.copy[parseInt(copySub)]) ? item.copy[parseInt(copySub)].content : '';
        } else if (copyType === 'image') {
          content = item.image || '';
        } else if (copyType === 'video') {
          content = item.video || '';
        }
        if (!content) return;

        navigator.clipboard.writeText(content).then(function() {
          var orig = btn.innerHTML;
          btn.innerHTML = '✅ 已复制';
          setTimeout(function() { btn.innerHTML = orig; }, 2000);
        }).catch(function() { alert('复制失败'); });
      });
    });

    // 绑定一键填写
    document.querySelectorAll('.pub-oneclick-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var cardIndex = parseInt(btn.dataset.cardIndex);
        var platformKey = btn.dataset.platformKey;
        var copySub = btn.dataset.copySub;
        var copyType = btn.dataset.copyType;
        var item = historyCache[cardIndex];
        if (!item) return;

        var title = '';
        var content = '';
        if (copyType === 'image') {
          title = item.product || '';
          content = item.image || '';
        } else if (copyType === 'video') {
          title = item.product || '';
          content = item.video || '';
        } else if (copySub !== undefined) {
          title = (item.copy && item.copy[parseInt(copySub)]) ? (item.copy[parseInt(copySub)].title || item.product || '') : '';
          content = (item.copy && item.copy[parseInt(copySub)]) ? item.copy[parseInt(copySub)].content : '';
        }
        if (!content) return;

        oneClickFill(title, content, platformKey);
        var orig = btn.innerHTML;
        btn.innerHTML = '✅ 已打开';
        setTimeout(function() { btn.innerHTML = orig; }, 2000);
      });
    });

    // 绑定删除
    document.querySelectorAll('.delete-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var cardIndex = parseInt(btn.dataset.cardIndex);
        if (!confirm('确定要删除这条记录吗？')) return;
        var history = loadHistory();
        history.splice(cardIndex, 1);
        saveHistory(history);
        renderHistory();
      });
    });
  }

  // 油猴脚本弹窗
  function showInstallModal() {
    document.getElementById('install-modal').style.display = 'flex';
  }
  function closeInstallModal(dontShowAgain) {
    document.getElementById('install-modal').style.display = 'none';
    if (dontShowAgain) localStorage.setItem('sm_script_installed', '1');
  }
  // 首次点击一键填写时弹窗
  document.querySelectorAll('.pub-oneclick-btn').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      if (!localStorage.getItem('sm_script_installed')) {
        var pk = btn.dataset.platformKey || '';
        if (pk !== 'weibo') showInstallModal();
      }
    }, true);
  });

  // 恢复 banner 状态
  if (localStorage.getItem('sm_hide_banner') === '1') {
    var b = document.getElementById('userscript-banner');
    if (b) b.style.display = 'none';
  }

  renderHistory();

  // 检测新内容
  (function checkNewContent() {
    var history = loadHistory();
    if (history.length === 0) return;
    var latest = history[history.length - 1];
    if (latest.id) {
      var age = Date.now() - parseInt(latest.id);
      if (age < 2 * 60 * 1000 && age > 0) {
        document.getElementById('new-content-banner').classList.remove('hidden');
        document.getElementById('history-list').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
  })();
</script>
</Base>
