---
interface Props {
  title: string;
  active?: string;
}
const { title, active = '' } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} - 智能营销</title>
  <meta name="description" content="AI驱动的一站式智能营销平台，支持多平台文案生成、批量推广、内容发布管理" />
</head>
<body class="bg-gray-50 min-h-screen" data-active={active}>
  <!-- Navigation -->
  <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
      <a href="/" class="text-lg font-bold text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-indigo-600">
        🚀 智能营销
      </a>
      <div class="flex items-center gap-1">
        <a href="/" class="nav-link px-3 py-1.5 rounded-lg text-sm " data-nav="home">首页</a>
        <a href="/copy" class="nav-link px-3 py-1.5 rounded-lg text-sm" data-nav="copy">文案生成</a>
        <a href="/generate" class="nav-link px-3 py-1.5 rounded-lg text-sm" data-nav="generate">批量推广</a>
        <a href="/publish" class="nav-link px-3 py-1.5 rounded-lg text-sm" data-nav="publish">发布管理</a>
        <a href="/#workflow" class="nav-link px-3 py-1.5 rounded-lg text-sm" data-nav="workflow">⚙️ 工作流</a>
      </div>
    </div>
  </nav>

  <slot />

  <script is:inline>
    // Highlight active nav
    const active = document.body.getAttribute('data-active') || '';
    document.querySelectorAll('.nav-link').forEach(link => {
      if (link.dataset.nav === active) {
        link.classList.add('bg-purple-50', 'text-purple-700', 'font-medium');
      } else {
        link.classList.add('text-gray-600', 'hover:bg-gray-100');
      }
    });

    // ========== 工作流自动生成检查 ==========
    (async function checkWorkflowAutoGen() {
      // 首页的工作流区自己处理自动生成
      if (active === 'home' || active === 'workflow') return;

      const FREQ_MS = { daily: 86400000, '2days': 172800000, weekly: 604800000 };
      let wfs;
      try { wfs = JSON.parse(localStorage.getItem('smart_marketing_workflows') || '[]'); } catch { return; }
      if (!wfs.length) return;

      // 找出需要自动生成的工作流
      const pending = wfs.filter(wf => {
        if (!wf.enabled || wf.frequency === 'manual') return false;
        if (!wf.lastGenerated) return true;
        return (Date.now() - wf.lastGenerated) >= (FREQ_MS[wf.frequency] || 86400000);
      });
      if (!pending.length) return;

      // 逐个生成
      for (const wf of pending) {
        try {
          const hasMulti = (wf.types.copy ? 1 : 0) + (wf.types.image ? 1 : 0) + (wf.types.video ? 1 : 0) > 1;
          const type = hasMulti ? 'batch' : (wf.types.copy ? 'copy' : (wf.types.image ? 'image' : 'video'));

          const res = await fetch('/api/generate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ type, product: wf.description, platforms: wf.platforms, extra: wf.extra || '' }),
          });
          const data = await res.json();
          if (!data.success) continue;

          // 保存到历史
          const entry = { id: Date.now().toString(), date: new Date().toLocaleDateString('zh-CN'), product: wf.product, platforms: wf.platforms };
          if (data.results.copy) entry.copy = data.results.copy;
          if (data.results.image) entry.image = data.results.image;
          if (data.results.video) entry.video = data.results.video;

          const history = JSON.parse(localStorage.getItem('smart_marketing_history') || '[]');
          history.push(entry);
          localStorage.setItem('smart_marketing_history', JSON.stringify(history));

          // 更新上次生成时间
          const updatedWfs = JSON.parse(localStorage.getItem('smart_marketing_workflows') || '[]');
          const idx = updatedWfs.findIndex(w => w.id === wf.id);
          if (idx >= 0) { updatedWfs[idx].lastGenerated = Date.now(); localStorage.setItem('smart_marketing_workflows', JSON.stringify(updatedWfs)); }

          console.log(`[工作流] 已自动生成: ${wf.product}`);
          await new Promise(r => setTimeout(r, 1000));
        } catch (e) { console.error('[工作流] 自动生成失败:', e); }
      }
    })();
  </script>
</body>
</html>

<style is:inline>
  .nav-link { transition: all 0.15s; }
</style>
