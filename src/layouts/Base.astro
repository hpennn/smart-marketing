---
interface Props {
  title: string;
  active?: string;
}
const { title, active = '' } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} - 智能营销</title>
  <meta name="description" content="AI驱动的一站式智能营销平台，支持多平台文案生成、批量推广、内容发布管理" />
  <meta name="baidu-site-verification" content="codeva-kIzibkIRds" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#7c3aed" />
  <!-- 百度统计 -->
  <script>
  var _hmt = _hmt || [];
  (function() {
    var hm = document.createElement("script");
    hm.src = "https://hm.baidu.com/hm.js?ec6e042b59844d38e3923b7467566f48";
    var s = document.getElementsByTagName("script")[0];
    s.parentNode.insertBefore(hm, s);
  })();
  </script>
</head>
<body class="bg-gray-50 min-h-screen" data-active={active}>

  <!-- 左侧导航栏（桌面端） -->
  <aside class="hidden md:flex fixed left-0 top-0 bottom-0 w-60 bg-white border-r border-gray-200 flex-col z-40">
    <!-- Logo -->
    <div class="h-16 flex items-center px-6 border-b border-gray-100">
      <a href="/" class="text-xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-indigo-600 flex items-center gap-2">
        🚀 智能营销
      </a>
    </div>
    <!-- 导航菜单 -->
    <nav class="flex-1 py-4 px-3 space-y-1">
      <a href="/" class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all" data-nav="home">
        <span class="text-lg">🏠</span>
        <span>首页</span>
      </a>
      <a href="/copy" class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all" data-nav="copy">
        <span class="text-lg">✍️</span>
        <span>文案生成</span>
      </a>
      <a href="/generate" class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all" data-nav="generate">
        <span class="text-lg">🚀</span>
        <span>批量推广</span>
      </a>
      <a href="/publish" class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all" data-nav="publish">
        <span class="text-lg">📢</span>
        <span>发布管理</span>
      </a>
      <a href="/#workflow" class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all" data-nav="workflow">
        <span class="text-lg">⚙️</span>
        <span>工作流</span>
      </a>
    </nav>
    <!-- 底部信息 -->
    <div class="px-6 py-4 border-t border-gray-100">
      <p class="text-xs text-gray-400">AI 驱动 · 多平台营销</p>
    </div>
  </aside>

  <!-- 主内容区 -->
  <div class="md:ml-60 pb-16 md:pb-0">
    <!-- 移动端顶部导航栏 -->
    <header class="md:hidden bg-white border-b border-gray-200 sticky top-0 z-30">
      <div class="px-4 h-14 flex items-center justify-center">
        <span class="text-lg font-bold text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-indigo-600">
          🚀 {title}
        </span>
      </div>
    </header>

    <!-- 页面内容 -->
    <slot />
  </div>

  <!-- 底部 Tab 导航（移动端 PWA 风格） -->
  <nav class="md:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 z-50 safe-bottom">
    <div class="flex items-center justify-around h-16">
      <a href="/" class="tab-bar-link flex flex-col items-center justify-center flex-1 h-full py-1" data-nav="home">
        <span class="text-xl mb-0.5">🏠</span>
        <span class="text-[10px] font-medium">首页</span>
      </a>
      <a href="/copy" class="tab-bar-link flex flex-col items-center justify-center flex-1 h-full py-1" data-nav="copy">
        <span class="text-xl mb-0.5">✍️</span>
        <span class="text-[10px] font-medium">文案</span>
      </a>
      <a href="/generate" class="tab-bar-link flex flex-col items-center justify-center flex-1 h-full py-1" data-nav="generate">
        <span class="text-xl mb-0.5">🚀</span>
        <span class="text-[10px] font-medium">推广</span>
      </a>
      <a href="/publish" class="tab-bar-link flex flex-col items-center justify-center flex-1 h-full py-1" data-nav="publish">
        <span class="text-xl mb-0.5">📢</span>
        <span class="text-[10px] font-medium">发布</span>
      </a>
    </div>
  </nav>

  <script is:inline>
    // Highlight active nav - sidebar
    var active = document.body.getAttribute('data-active') || '';
    document.querySelectorAll('.sidebar-link').forEach(function(link) {
      if (link.dataset.nav === active) {
        link.classList.add('bg-purple-50', 'text-purple-700');
      } else {
        link.classList.add('text-gray-600', 'hover:bg-gray-50');
      }
    });
    // Highlight active nav - bottom tab bar
    document.querySelectorAll('.tab-bar-link').forEach(function(link) {
      if (link.dataset.nav === active) {
        link.classList.add('text-purple-600');
      } else {
        link.classList.add('text-gray-400');
      }
    });
  </script>

  <!-- 注册 Service Worker -->
  <script is:inline>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js').catch(function(){});
    }
  </script>
</body>
</html>

<style is:inline>
  .sidebar-link, .tab-bar-link { transition: all 0.15s; }
  .safe-bottom { padding-bottom: env(safe-area-inset-bottom, 0px); }
</style>
